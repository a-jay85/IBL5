#!/bin/bash
# Download the DuckDB CLI binary for the current platform.
# Places the binary at ibl5/analytics/duckdb (gitignored).
#
# Usage: bin/analytics-setup [version]
#   version  DuckDB release tag (default: v1.2.1)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DUCKDB_DIR="$REPO_ROOT/ibl5/analytics"
DUCKDB_BIN="$DUCKDB_DIR/duckdb"
VERSION="${1:-v1.2.1}"

if [ -x "$DUCKDB_BIN" ]; then
    CURRENT=$("$DUCKDB_BIN" --version 2>/dev/null | head -1 || true)
    echo "DuckDB already installed: $CURRENT"
    echo "To reinstall, delete $DUCKDB_BIN and re-run."
    exit 0
fi

# Detect platform
OS="$(uname -s)"
ARCH="$(uname -m)"

case "$OS-$ARCH" in
    Darwin-arm64)
        PLATFORM="osx-universal"
        ;;
    Darwin-x86_64)
        PLATFORM="osx-universal"
        ;;
    Linux-x86_64)
        PLATFORM="linux-amd64"
        ;;
    Linux-aarch64)
        PLATFORM="linux-aarch64"
        ;;
    *)
        echo "Unsupported platform: $OS-$ARCH" >&2
        exit 1
        ;;
esac

URL="https://github.com/duckdb/duckdb/releases/download/${VERSION}/duckdb_cli-${PLATFORM}.zip"

echo "Downloading DuckDB ${VERSION} for ${PLATFORM}..."
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

curl -fsSL "$URL" -o "$TMPDIR/duckdb.zip"
unzip -q "$TMPDIR/duckdb.zip" -d "$TMPDIR"
mv "$TMPDIR/duckdb" "$DUCKDB_BIN"
chmod +x "$DUCKDB_BIN"

echo "Installed: $("$DUCKDB_BIN" --version)"
echo "Location: $DUCKDB_BIN"
