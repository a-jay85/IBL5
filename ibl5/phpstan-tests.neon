includes:
    - phar://phpstan.phar/conf/bleedingEdge.neon
    - phpstan-tests-baseline.neon

parameters:
    level: 6
    paths:
        - tests
    excludePaths:
        - tests/TeamOffDefStats/TeamOffDefStatsRepositoryTest.php
        # Rule-test fixtures are deliberately-broken inputs to RuleTestCase
        # (intentional rule violations, missing strict_types, etc.). They are
        # loaded by path inside the rule tests, never analysed as real code.
        - tests/PHPStanRules/Fixtures/*
    bootstrapFiles:
        - phpstan-stubs/nuke-globals.stub.php
        - phpstan-stubs/mock-aliases.stub.php
    phpVersion: 80300
    treatPhpDocTypesAsCertain: false

services:
    -
        class: PHPStanRules\RequireStrictTypesRule
        tags:
            - phpstan.rules.rule
    -
        class: PHPStanRules\RequireMeaningfulAssertionsRule
        tags:
            - phpstan.rules.rule
