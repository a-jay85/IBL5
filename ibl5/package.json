{
  "name": "ibl5-design",
  "version": "1.0.0",
  "description": "IBL5 Design System with Tailwind CSS 4",
  "type": "module",
  "scripts": {
    "css:watch": "bunx @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css --watch",
    "css:build": "bunx @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css --minify",
    "test:e2e": "bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:isolated": "./bin/e2e-local.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
