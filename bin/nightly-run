#!/bin/bash
# Wrapper script for the IBL5 nightly autonomous workflow.
# Called by launchd at 00:03 and 11:00 daily. Loops through queued plans,
# firing two claude -p invocations per plan (implementation + post-plan)
# until the queue is empty or the time guard is exceeded.
#
# To test manually: bin/nightly-run
# To force-trigger via launchd: launchctl start com.ibl5.nightly-claude
# To schedule a one-shot run: bin/nightly-run schedule "2026-05-28 20:00 PDT"

set -euo pipefail

# launchd runs with minimal env — ensure our tools are findable
export PATH="/usr/local/bin:/opt/homebrew/bin:$HOME/.bun/bin:$HOME/.local/bin:/Applications/cmux.app/Contents/Resources/bin:$PATH"

# --- One-shot scheduler subcommand ----------------------------------------
# Usage: bin/nightly-run schedule "YYYY-MM-DD HH:MM [TZ]"
# Creates a self-cleaning launchd agent that fires bin/nightly-run once at the
# given time, then removes its own plist and boots itself out. The timezone
# abbreviation is optional and defaults to the system's local zone.
# Example: bin/nightly-run schedule "2026-05-28 20:00 PDT"
if [ "${1:-}" = "schedule" ]; then
    WHEN="${2:-}"
    if [ -z "$WHEN" ]; then
        echo "usage: bin/nightly-run schedule \"YYYY-MM-DD HH:MM [TZ]\"" >&2
        echo "example: bin/nightly-run schedule \"2026-05-28 20:00 PDT\"" >&2
        exit 1
    fi

    # Resolve to an epoch — try with a timezone abbreviation first, then local.
    EPOCH=$(date -j -f '%Y-%m-%d %H:%M %Z' "$WHEN" +%s 2>/dev/null || true)
    if [ -z "$EPOCH" ]; then
        EPOCH=$(date -j -f '%Y-%m-%d %H:%M' "$WHEN" +%s 2>/dev/null || true)
    fi
    if [ -z "$EPOCH" ]; then
        echo "error: could not parse time '$WHEN'" >&2
        echo "expected: YYYY-MM-DD HH:MM [TZ]  (e.g. 2026-05-28 20:00 PDT)" >&2
        exit 1
    fi

    if [ "$EPOCH" -le "$(date +%s)" ]; then
        echo "error: '$WHEN' resolves to the past ($(date -r "$EPOCH" '+%Y-%m-%d %H:%M %Z'))" >&2
        exit 1
    fi

    # launchd StartCalendarInterval is interpreted in system-local time — derive
    # local calendar components from the resolved epoch. 10# forces base-10 so
    # values like 08/09 don't trip bash's octal parser.
    CAL_MONTH=$((10#$(date -r "$EPOCH" +%m)))
    CAL_DAY=$((10#$(date -r "$EPOCH" +%d)))
    CAL_HOUR=$((10#$(date -r "$EPOCH" +%H)))
    CAL_MIN=$((10#$(date -r "$EPOCH" +%M)))
    LOCAL_STR=$(date -r "$EPOCH" '+%Y-%m-%d %H:%M %Z')

    LABEL="com.ibl5.nightly-oneshot-$EPOCH"
    PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
    SELF="/Users/ajaynicolas/GitHub/IBL5/bin/nightly-run"
    OUT_LOG="$HOME/.claude/projects/-Users-ajaynicolas-GitHub-IBL5/nightly/logs/launchd-oneshot-stdout.log"
    ERR_LOG="$HOME/.claude/projects/-Users-ajaynicolas-GitHub-IBL5/nightly/logs/launchd-oneshot-stderr.log"
    mkdir -p "$(dirname "$OUT_LOG")"

    cat > "$PLIST" <<PLIST_EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>$LABEL</string>
	<key>ProgramArguments</key>
	<array>
		<string>/bin/bash</string>
		<string>-lc</string>
		<string>$SELF; rm -f "$PLIST"; launchctl bootout gui/\$(id -u)/$LABEL</string>
	</array>
	<key>StartCalendarInterval</key>
	<dict>
		<key>Month</key>
		<integer>$CAL_MONTH</integer>
		<key>Day</key>
		<integer>$CAL_DAY</integer>
		<key>Hour</key>
		<integer>$CAL_HOUR</integer>
		<key>Minute</key>
		<integer>$CAL_MIN</integer>
	</dict>
	<key>WorkingDirectory</key>
	<string>/Users/ajaynicolas/GitHub/IBL5</string>
	<key>StandardOutPath</key>
	<string>$OUT_LOG</string>
	<key>StandardErrorPath</key>
	<string>$ERR_LOG</string>
</dict>
</plist>
PLIST_EOF

    launchctl bootout "gui/$(id -u)/$LABEL" 2>/dev/null || true
    launchctl bootstrap "gui/$(id -u)" "$PLIST"

    echo "Scheduled one-shot nightly-run:"
    echo "  fires:  $LOCAL_STR  (local time)"
    echo "  label:  $LABEL"
    echo "  plist:  $PLIST"
    echo "  note:   runs only if the Mac is awake then; self-removes after firing."
    exit 0
fi

# Burst mode: if NIGHTLY_BURST is set, check cutoff and self-revert when expired.
if [ "${NIGHTLY_BURST:-}" = "1" ] && [ -n "${NIGHTLY_BURST_CUTOFF:-}" ]; then
    BURST_PLIST="$HOME/Library/LaunchAgents/com.ibl5.nightly-claude.plist"
    BURST_BACKUP="$HOME/Library/LaunchAgents/com.ibl5.nightly-claude.plist.backup-pre-burst"
    # Compare current time against cutoff (both in local time)
    if [ "$(date +%s)" -ge "$(date -j -f '%Y-%m-%dT%H:%M:%S' "$NIGHTLY_BURST_CUTOFF" +%s 2>/dev/null || echo 0)" ]; then
        echo "$(date '+%Y-%m-%d %H:%M:%S') Burst cutoff reached ($NIGHTLY_BURST_CUTOFF). Restoring production plist."
        if [ -f "$BURST_BACKUP" ]; then
            launchctl remove com.ibl5.nightly-claude 2>/dev/null || true
            sleep 1
            cp "$BURST_BACKUP" "$BURST_PLIST"
            rm -f "$BURST_BACKUP"
            launchctl load "$BURST_PLIST"
            echo "$(date '+%Y-%m-%d %H:%M:%S') Production plist restored. Burst schedule removed."
        else
            echo "$(date '+%Y-%m-%d %H:%M:%S') WARNING: No backup plist found at $BURST_BACKUP"
        fi
        exit 0
    fi
fi

# macOS doesn't ship GNU timeout — prefer coreutils gtimeout, else use a shim.
# The shim must close inherited pipeline fds inside the timer subshell (bash 3.2
# doesn't reliably apply external redirects on backgrounded subshells in pipes).
if command -v gtimeout &>/dev/null; then
    timeout() {
        local secs=$1; shift
        "$@" &
        local cmd_pid=$!
        if [ -n "${NIGHTLY_CMDPID_FILE:-}" ]; then
            echo "$cmd_pid" > "$NIGHTLY_CMDPID_FILE"
        fi
        ( exec 0</dev/null 1>/dev/null 2>&1
          sleep "$secs" && kill -TERM "$cmd_pid" 2>/dev/null
        ) &
        local timer_pid=$!
        local status=0
        wait "$cmd_pid" || status=$?
        pkill -P "$timer_pid" 2>/dev/null || true
        kill "$timer_pid" 2>/dev/null || true
        wait "$timer_pid" 2>/dev/null || true
        return "$status"
    }
elif ! command -v timeout &>/dev/null; then
    # NIGHTLY_CMDPID_FILE: if set, the timeout shim writes the backgrounded
    # command's PID there so the heartbeat watcher can stall-kill it.
    timeout() {
        local secs=$1; shift
        "$@" &
        local cmd_pid=$!
        if [ -n "${NIGHTLY_CMDPID_FILE:-}" ]; then
            echo "$cmd_pid" > "$NIGHTLY_CMDPID_FILE"
        fi
        # exec inside subshell guarantees fd closure (bash 3.2 pipeline compat)
        ( exec 0</dev/null 1>/dev/null 2>&1
          sleep "$secs" && kill -TERM "$cmd_pid" 2>/dev/null
        ) &
        local timer_pid=$!
        local status=0
        wait "$cmd_pid" || status=$?
        pkill -P "$timer_pid" 2>/dev/null || true
        kill "$timer_pid" 2>/dev/null || true
        wait "$timer_pid" 2>/dev/null || true
        return "$status"
    }
fi

# Signal to /post-plan that we're running headless (skips Phase 11:
# Worktree Preview Environment — no human present to verify)
export CLAUDE_HEADLESS=1

REPO="/Users/ajaynicolas/GitHub/IBL5"
NIGHTLY_DIR="$HOME/.claude/projects/-Users-ajaynicolas-GitHub-IBL5/nightly"
LOG_DIR="$NIGHTLY_DIR/logs"
QUEUE_DIR="$NIGHTLY_DIR/queue"
MAX_ELAPSED=17100  # ~4h45m — stops around 4:45am, leaves headroom in the 5h usage window
MAX_ATTEMPTS=3     # per-plan retry cap within one night (covers impl + postplan phases)
MAX_IMPL_SECS=3600   # per-phase cap: impl gets at most 1h
MAX_PP_SECS=3600     # per-phase cap: post-plan gets at most 1h
STALL_KILL_SECS=600  # kill phase if no stream events for 10 minutes
ARCHIVE_AGE_DAYS="${NIGHTLY_ARCHIVE_AGE_DAYS:-7}"  # startup-archive entries idle this many days
MIN_VIABLE_SECS=60   # a real impl/postplan never finishes (pass OR fail) under a
                     # minute — historical runs are 15-50 min; environmental
                     # fast-fails (usage/rate limit, auth error, transient) exit in
                     # 2-5s. A sub-minute exit is therefore environmental, not a
                     # plan failure: stop the night, don't burn the queue to skipped/.

HANDOFF_DIR="$NIGHTLY_DIR/handoff"
mkdir -p "$LOG_DIR" "$QUEUE_DIR" "$HANDOFF_DIR"

WATCHER_PID=""
cleanup_watcher() {
    if [ -n "$WATCHER_PID" ]; then
        kill "$WATCHER_PID" 2>/dev/null || true
        wait "$WATCHER_PID" 2>/dev/null || true
    fi
    rm -f "$NIGHTLY_DIR/.heartbeat-$$-impl" "$NIGHTLY_DIR/.heartbeat-$$-postplan" \
         "$NIGHTLY_DIR/.cmdpid-$$-impl" "$NIGHTLY_DIR/.cmdpid-$$-postplan" 2>/dev/null || true
}
trap cleanup_watcher EXIT

run_heartbeat_watcher() {
    local hb_file=$1 log_file=$2 label=$3 pid_file=$4
    while sleep 60; do
        if [ ! -f "$hb_file" ]; then
            continue
        fi
        local last_epoch now age
        last_epoch=$(cat "$hb_file" 2>/dev/null) || continue
        [ -n "$last_epoch" ] || continue
        now=$(date +%s)
        age=$(( now - last_epoch ))
        local ts
        ts=$(date +%H:%M:%S)
        if [ "$age" -gt "$STALL_KILL_SECS" ]; then
            local target_pid
            target_pid=$(cat "$pid_file" 2>/dev/null) || true
            if [ -n "$target_pid" ] && kill -0 "$target_pid" 2>/dev/null; then
                printf '[%s] STALL-KILL: %s — no events for %ds, killing pid %s and children\n' \
                    "$ts" "$label" "$age" "$target_pid" >> "$log_file"
                pkill -TERM -P "$target_pid" 2>/dev/null || true
                kill -TERM "$target_pid" 2>/dev/null || true
                return
            else
                printf '[%s] WARNING: %s — no events for %ds (stalled, pid gone)\n' \
                    "$ts" "$label" "$age" >> "$log_file"
            fi
        elif [ "$age" -gt 300 ]; then
            printf '[%s] WARNING: %s — no events for %ds (possibly stalled)\n' "$ts" "$label" "$age" >> "$log_file"
        else
            printf '[%s] heartbeat: %s alive (%ds since last event)\n' "$ts" "$label" "$age" >> "$log_file"
        fi
    done
}

# Append a per-phase cost row to the night's cost roll-up. Cost is parsed from
# the phase's `exit:` line (emitted by nightly-stream-filter into the log). One
# row per phase keeps this robust across split impl/postplan invocations — no
# cross-phase variable dependency. See .claude/rules/nightly-workflow.md.
append_cost_row() {
    local plan=$1 phase=$2 log_before=$3
    local cost report
    # `|| true` is load-bearing: under `set -euo pipefail` a killed phase emits no
    # `cost=` line, so grep exits non-zero and this plain assignment would abort the
    # whole nightly loop before the `cost="?"` fallback below. Swallow it and continue.
    cost=$(tail -n +"$((log_before + 1))" "$LOG" | grep -oE 'cost=\$[0-9.]+' | tail -1 | sed 's/cost=\$//') || true
    [ -n "$cost" ] || cost="?"
    report="$NIGHTLY_DIR/reports/$(date +%Y-%m-%d)-costs.md"
    mkdir -p "$(dirname "$report")"
    if [ ! -f "$report" ]; then
        printf '# Nightly cost roll-up — %s\n\n| Plan | Phase | Cost ($) |\n|---|---|---|\n' \
            "$(date +%Y-%m-%d)" > "$report"
    fi
    printf '| %s | %s | %s |\n' "$plan" "$phase" "$cost" >> "$report"
}

# Decrement the current plan's attempt counter by one ("refund"). Used when a
# phase is cut short by an environmental failure (usage/rate limit, auth error,
# transient) rather than a genuine plan failure — the plan should retry cleanly
# next run, not march toward the poison-pill skip threshold.
refund_attempt() {
    local current
    current=$(cat "$ATTEMPT_FILE" 2>/dev/null || echo 0)
    if [ "$current" -le 1 ]; then
        rm -f "$ATTEMPT_FILE"
    else
        echo $(( current - 1 )) > "$ATTEMPT_FILE"
    fi
}

# Scan this phase's slice of the log for a known environmental-failure signature:
# a Claude usage/rate limit or an Anthropic API auth error, in any phrasing these
# surface in (the legacy single-string checks missed "weekly limit" and the plain
# "API Error: 401", causing whole queues to grind into skipped/). Patterns are
# kept specific to Claude-runtime errors so a postplan security audit discussing
# auth code does not false-trigger. Returns 0 on match. Safe under `set -e`: only
# ever called inside an `if` condition.
phase_env_error() {
    local log_before=$1
    tail -n +"$(( log_before + 1 ))" "$LOG" 2>/dev/null | grep -qiE \
        "hit your [a-z0-9 -]*limit|usage limit reached|api error:[[:space:]]*(401|403|429|529)|overloaded_error|rate_limit_error"
}

# Write a one-line report when the run STOPS on an environmental failure. The
# queue is left intact (nothing skipped), so without this a no-progress night —
# e.g. a single head-of-queue plan that keeps fast-failing — would be silent.
# Distinct filename prefix (env-stop) from the skip/error/done reports.
write_env_stop_report() {
    local plan=$1 phase=$2 reason=$3 log_before=$4
    local reports_dir="$NIGHTLY_DIR/reports" slug
    slug=$(basename "$plan" .md)
    mkdir -p "$reports_dir"
    {
        printf 'Nightly run STOPPED during %s of "%s" — %s.\n\n' "$phase" "$slug" "$reason"
        printf 'The queue was left intact — no plans were skipped. It resumes next run.\n'
        printf 'If this recurs for the same plan, that plan may be malformed — review it.\n\n'
        printf '## Phase log tail\n\n```\n'
        tail -n +"$(( log_before + 1 ))" "$LOG" 2>/dev/null | tail -20 || true
        printf '\n```\n'
    } > "$reports_dir/$(date +%Y-%m-%d)-env-stop-$slug.md"
}

# Move entries in a nightly subdir untouched for $ARCHIVE_AGE_DAYS into a sibling
# `<subdir>.archive/`, keeping the working dirs small without deleting history.
# Matches regular files AND symlinks; `find` does not follow symlinks, so a
# disposition symlink (done/, skipped/) is judged on its OWN mtime — the date it
# was moved there — not the plan file it points at. `+N` = strictly older than
# N*24h. Lazily creates the archive dir only when something actually moves.
# Caller scopes this under `|| true` so a failure here can never abort the night.
archive_stale() {
    local subdir=$1
    local src="$NIGHTLY_DIR/$subdir"
    local dest="$NIGHTLY_DIR/${subdir}.archive"
    [ -d "$src" ] || return 0
    local moved=0 entry
    while IFS= read -r entry; do
        [ -n "$entry" ] || continue
        mkdir -p "$dest"
        mv "$entry" "$dest/" 2>/dev/null && moved=$(( moved + 1 ))
    done < <(find "$src" -mindepth 1 -maxdepth 1 \( -type f -o -type l \) \
                  -mtime +"$ARCHIVE_AGE_DAYS" 2>/dev/null)
    [ "$moved" -eq 0 ] || echo "Archived $moved stale entr$([ "$moved" -eq 1 ] && echo y || echo ies) from $subdir/ → ${subdir}.archive/" >> "$LOG"
}

LOG="$LOG_DIR/$(date +%Y-%m-%d).log"

cd "$REPO"

# Prevent macOS from sleeping while we run (released automatically on exit)
caffeinate -s -w $$ &
CAFFEINATE_PID=$!

START=$(date +%s)
PLANS_RUN=0

echo "=== Nightly session starting at $(date) ===" >> "$LOG"

# Startup archival: shrink the accumulating output dirs by moving entries idle
# for $ARCHIVE_AGE_DAYS into sibling `.archive/` folders. queue/ (pending work,
# iterated below) and handoff/ (transient, cleaned at loop end) are excluded by
# design. Whole block guarded so an archival hiccup never stops the night.
{
    archive_stale logs
    archive_stale reports
    archive_stale "done"
    archive_stale skipped
} || true

while true; do
    # Check if queue has plans
    if ! ls "$QUEUE_DIR"/*.md &>/dev/null; then
        if [ "$PLANS_RUN" -eq 0 ]; then
            echo "Queue empty — nothing to run." >> "$LOG"
            mkdir -p "$NIGHTLY_DIR/reports"
            echo "No plan queued for tonight." \
                > "$NIGHTLY_DIR/reports/$(date +%Y-%m-%d)-no-queue.md"
        else
            echo "Queue drained after $PLANS_RUN plan(s)." >> "$LOG"
        fi
        break
    fi

    # Time guard: don't start a new plan if >4h elapsed
    ELAPSED=$(( $(date +%s) - START ))
    if [ "$ELAPSED" -gt "$MAX_ELAPSED" ]; then
        echo "Time guard: ${ELAPSED}s elapsed (max ${MAX_ELAPSED}s), stopping." >> "$LOG"
        break
    fi

    # Pick the oldest queued plan
    NEXT_PLAN=$(ls -1tr "$QUEUE_DIR"/*.md 2>/dev/null | head -1)
    PLAN_NAME=$(basename "$NEXT_PLAN")

    # Per-plan retry counter — skip poison pills
    ATTEMPT_FILE="$QUEUE_DIR/${PLAN_NAME}.attempts"
    ATTEMPTS=0
    if [ -f "$ATTEMPT_FILE" ]; then
        ATTEMPTS=$(cat "$ATTEMPT_FILE")
    fi
    if [ "$ATTEMPTS" -ge "$MAX_ATTEMPTS" ]; then
        echo "Plan $PLAN_NAME failed $ATTEMPTS times — moving to skipped/." >> "$LOG"
        mkdir -p "$NIGHTLY_DIR/skipped"
        mv "$NEXT_PLAN" "$NIGHTLY_DIR/skipped/"
        rm -f "$ATTEMPT_FILE"
        REPORTS_DIR="$NIGHTLY_DIR/reports"
        mkdir -p "$REPORTS_DIR"
        SLUG=$(basename "$PLAN_NAME" .md)
        {
            printf 'Plan "%s" skipped after %d failed attempts in one night. Needs human review.\n\n' \
                "$SLUG" "$ATTEMPTS"
            printf '## Last attempt log tail\n\n```\n'
            tail -30 "$LOG"
            printf '\n```\n'
        } > "$REPORTS_DIR/$(date +%Y-%m-%d)-skipped-$SLUG.md"
        continue
    fi

    # Increment attempt counter
    echo $(( ATTEMPTS + 1 )) > "$ATTEMPT_FILE"

    PLANS_RUN=$(( PLANS_RUN + 1 ))
    echo "--- Plan #$PLANS_RUN: $PLAN_NAME (attempt $(( ATTEMPTS + 1 ))) at $(date) ---" >> "$LOG"

    # --- Phase 1: Implementation ---
    # Skip if handoff file exists (resume: impl done, postplan pending)
    HANDOFF_FILE="$HANDOFF_DIR/${PLAN_NAME}.json"

    if [ -f "$HANDOFF_FILE" ]; then
        echo "Handoff exists — skipping impl, proceeding to post-plan." >> "$LOG"
    else
        REMAINING_SECS=$(( MAX_ELAPSED - $(( $(date +%s) - START )) ))
        if [ "$REMAINING_SECS" -lt 300 ]; then
            REMAINING_SECS=300
        fi
        # Per-phase cap: don't let one impl consume the whole night
        if [ "$REMAINING_SECS" -gt "$MAX_IMPL_SECS" ]; then
            REMAINING_SECS="$MAX_IMPL_SECS"
        fi
        IMPL_LOG_BEFORE=$(wc -l < "$LOG" 2>/dev/null || echo 0)
        HEARTBEAT_FILE="$NIGHTLY_DIR/.heartbeat-$$-impl"
        CMDPID_FILE="$NIGHTLY_DIR/.cmdpid-$$-impl"
        rm -f "$HEARTBEAT_FILE" "$CMDPID_FILE"

        run_heartbeat_watcher "$HEARTBEAT_FILE" "$LOG" "impl:$PLAN_NAME" "$CMDPID_FILE" &
        WATCHER_PID=$!

        IMPL_STATUS=0
        IMPL_START=$(date +%s)
        # Per-plan model selection: a plan may declare `impl_model:` in its
        # first frontmatter block; absent/unknown → Opus default.
        # Both invocations pass `--effort high` explicitly to pin reasoning
        # depth regardless of the user's interactive `/effort` setting (which
        # writes ~/.claude/settings.json effortLevel). Do not remove as
        # "redundant with the default" — the pin is the point.
        IMPL_MODEL=$(bin/lib/plan-impl-model "$NEXT_PLAN")
        echo "[$(date +%H:%M:%S)] impl model: $IMPL_MODEL for $PLAN_NAME" >> "$LOG"
        NIGHTLY_CMDPID_FILE="$CMDPID_FILE" \
        timeout "$REMAINING_SECS" \
            claude -p "$(cat bin/nightly-prompt-impl)

PLAN_FILE=$PLAN_NAME" \
                --dangerously-skip-permissions \
                --model "$IMPL_MODEL" \
                --effort high \
                --output-format stream-json \
                --verbose \
                --name "nightly-impl-$(date +%Y-%m-%d-%H%M)" \
            2> >(grep -v 'thinking.type=enabled' >> "$LOG") \
            | bin/lib/nightly-stream-filter "$HEARTBEAT_FILE" "$CMDPID_FILE" \
            >> "$LOG" || IMPL_STATUS=$?

        kill "$WATCHER_PID" 2>/dev/null || true
        wait "$WATCHER_PID" 2>/dev/null || true
        WATCHER_PID=""
        rm -f "$HEARTBEAT_FILE" "$CMDPID_FILE"

        if [ "$IMPL_STATUS" -ne 0 ]; then
            printf '[%s] claude exited code=%d (impl phase)\n' "$(date +%H:%M:%S)" "$IMPL_STATUS" >> "$LOG"
        fi

        echo "--- Plan #$PLANS_RUN impl finished at $(date) ---" >> "$LOG"
        append_cost_row "$PLAN_NAME" impl "$IMPL_LOG_BEFORE"

        IMPL_DUR=$(( $(date +%s) - IMPL_START ))

        # Environmental-failure breaker. A usage/rate limit, auth error, or any
        # transient that kills the agent is NOT a plan failure — refund the attempt
        # and STOP so the queue survives intact (it resumes next run). Only when
        # impl produced no handoff; two independent signals, either suffices:
        #   1. a known limit/auth signature in this phase's log slice, or
        #   2. a sub-minute exit — real impls run 15-50 min, so a fast no-handoff
        #      exit is environmental whatever the phrasing, and (unlike string
        #      matching) is immune to the async-stderr log-flush race.
        # A slow failure with no signature falls through as a genuine plan failure,
        # keeping its incremented attempt → eventual poison-pill skip (unchanged).
        if [ ! -f "$HANDOFF_FILE" ] \
           && { phase_env_error "$IMPL_LOG_BEFORE" || [ "$IMPL_DUR" -lt "$MIN_VIABLE_SECS" ]; }; then
            REASON="usage/rate limit, auth error, or transient"
            if [ "$IMPL_DUR" -lt "$MIN_VIABLE_SECS" ]; then
                REASON="$REASON (impl exited in ${IMPL_DUR}s)"
            fi
            echo "Environmental failure during impl — $REASON. Refunding attempt, stopping loop." >> "$LOG"
            refund_attempt
            write_env_stop_report "$PLAN_NAME" impl "$REASON" "$IMPL_LOG_BEFORE"
            break
        fi

        # Handoff created → impl succeeded, reset attempt counter
        if [ -f "$HANDOFF_FILE" ]; then
            echo "Handoff file created — impl succeeded." >> "$LOG"
            rm -f "$ATTEMPT_FILE"
        fi
    fi

    # --- Phase 2: Post-Plan (only if handoff file exists) ---
    if [ -f "$HANDOFF_FILE" ]; then
        # Re-check time guard before starting post-plan
        ELAPSED=$(( $(date +%s) - START ))
        if [ "$ELAPSED" -gt "$MAX_ELAPSED" ]; then
            echo "Time guard between phases — will resume postplan next run." >> "$LOG"
            break
        fi

        REMAINING_SECS=$(( MAX_ELAPSED - $(( $(date +%s) - START )) ))
        if [ "$REMAINING_SECS" -lt 300 ]; then
            REMAINING_SECS=300
        fi
        if [ "$REMAINING_SECS" -gt "$MAX_PP_SECS" ]; then
            REMAINING_SECS="$MAX_PP_SECS"
        fi
        PP_LOG_BEFORE=$(wc -l < "$LOG" 2>/dev/null || echo 0)
        HEARTBEAT_FILE="$NIGHTLY_DIR/.heartbeat-$$-postplan"
        CMDPID_FILE="$NIGHTLY_DIR/.cmdpid-$$-postplan"
        rm -f "$HEARTBEAT_FILE" "$CMDPID_FILE"

        run_heartbeat_watcher "$HEARTBEAT_FILE" "$LOG" "postplan:$PLAN_NAME" "$CMDPID_FILE" &
        WATCHER_PID=$!

        PP_STATUS=0
        PP_START=$(date +%s)
        NIGHTLY_CMDPID_FILE="$CMDPID_FILE" \
        timeout "$REMAINING_SECS" \
            claude -p "$(cat bin/nightly-prompt-postplan)

PLAN_FILE=$PLAN_NAME" \
                --dangerously-skip-permissions \
                --model claude-sonnet-4-6 \
                --effort high \
                --output-format stream-json \
                --verbose \
                --name "nightly-postplan-$(date +%Y-%m-%d-%H%M)" \
            2> >(grep -v 'thinking.type=enabled' >> "$LOG") \
            | bin/lib/nightly-stream-filter "$HEARTBEAT_FILE" "$CMDPID_FILE" \
            >> "$LOG" || PP_STATUS=$?

        kill "$WATCHER_PID" 2>/dev/null || true
        wait "$WATCHER_PID" 2>/dev/null || true
        WATCHER_PID=""
        rm -f "$HEARTBEAT_FILE" "$CMDPID_FILE"

        if [ "$PP_STATUS" -ne 0 ]; then
            printf '[%s] claude exited code=%d (postplan phase)\n' "$(date +%H:%M:%S)" "$PP_STATUS" >> "$LOG"
        fi

        echo "--- Plan #$PLANS_RUN postplan finished at $(date) ---" >> "$LOG"
        append_cost_row "$PLAN_NAME" postplan "$PP_LOG_BEFORE"

        PP_DUR=$(( $(date +%s) - PP_START ))

        # Environmental-failure breaker (mirrors impl). A successful post-plan
        # removes the handoff (the agent moves the plan to done/ and deletes it),
        # so a handoff still present after a sub-minute exit means the agent never
        # ran — environmental. A known limit/auth signature stops regardless, so a
        # dead budget doesn't burn a postplan retry. Refund + stop; queue intact.
        if phase_env_error "$PP_LOG_BEFORE" \
           || { [ -f "$HANDOFF_FILE" ] && [ "$PP_DUR" -lt "$MIN_VIABLE_SECS" ]; }; then
            REASON="usage/rate limit, auth error, or transient"
            if [ "$PP_DUR" -lt "$MIN_VIABLE_SECS" ]; then
                REASON="$REASON (postplan exited in ${PP_DUR}s)"
            fi
            echo "Environmental failure during postplan — $REASON. Refunding attempt, stopping loop." >> "$LOG"
            refund_attempt
            write_env_stop_report "$PLAN_NAME" postplan "$REASON" "$PP_LOG_BEFORE"
            break
        fi
    fi

    # If the plan moved out of queue/ (to done/ or skipped/), clean up its attempt file
    if [ ! -e "$NEXT_PLAN" ]; then
        rm -f "$ATTEMPT_FILE"
    fi
done

# Clean up any leftover attempt files for plans that completed
for af in "$QUEUE_DIR"/*.attempts; do
    [ -e "$af" ] || continue
    PLAN_FOR_ATTEMPT="${af%.attempts}"
    if [ ! -e "$PLAN_FOR_ATTEMPT" ]; then
        rm -f "$af"
    fi
done

# Clean up orphaned handoff files (plan no longer in queue)
for hf in "$HANDOFF_DIR"/*.json; do
    [ -e "$hf" ] || continue
    PLAN_FOR_HANDOFF="$QUEUE_DIR/$(basename "${hf%.json}")"
    if [ ! -e "$PLAN_FOR_HANDOFF" ]; then
        rm -f "$hf"
    fi
done

echo "=== Nightly session complete at $(date) — $PLANS_RUN plan(s) run ===" >> "$LOG"
