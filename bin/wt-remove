#!/bin/bash
# Remove a git worktree, using --force because symlinked files
# (vendor/, config.php, .env.test, style.css) appear as untracked
# changes and block normal removal.
#
# Usage: bin/wt-remove <worktree-name>

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [ $# -lt 1 ]; then
    echo "Usage: bin/wt-remove <worktree-name>" >&2
    exit 1
fi

NAME="$1"

# Resolve the actual worktree path from git (handles worktrees created from
# subdirectories, e.g., ibl5/worktrees/ instead of worktrees/).
WT_PATH=$(git worktree list --porcelain | awk -v branch="refs/heads/$NAME" '
    /^worktree / { path = substr($0, 10) }
    $0 == "branch " branch { print path; exit }
')

# Fall back to the conventional location if git doesn't know the branch
# (e.g., branch already deleted but directory remains).
if [ -z "$WT_PATH" ]; then
    WT_PATH="$REPO_ROOT/worktrees/$NAME"
fi

if [ ! -d "$WT_PATH" ]; then
    echo "Error: worktree '$NAME' not found at $WT_PATH" >&2
    exit 1
fi

echo "Removing worktree '$NAME'..."
git worktree remove --force "$WT_PATH"
echo "Done. Worktree '$NAME' removed."
