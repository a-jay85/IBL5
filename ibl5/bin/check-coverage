#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . '/../vendor/autoload.php';

if ($argc < 3) {
    fwrite(STDERR, "Usage: php bin/check-coverage <clover-file> <threshold>\n");
    exit(1);
}

$cloverFile = $argv[1];
$threshold = (float) $argv[2];

$checker = new \Utilities\CoverageChecker();
$result = $checker->check($cloverFile, $threshold);

echo $result->getMessage() . "\n";
echo sprintf("  Coverage: %.2f%% | Threshold: %.2f%%\n", $result->getPercentage(), $result->getThreshold());

exit($result->passed() ? 0 : 1);
