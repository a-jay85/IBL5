#!/usr/bin/env bash
# shellcheck shell=bash
#
# bin/check-plan-staleness — staleness guard for automouse queued plans.
#
# Takes one argument: a plan file path (in production, the queue symlink that
# points at ~/.claude/plans/<name>.md). Scans the plan body for repo-path
# reference tokens and exits non-zero, printing each unresolved token, when the
# plan references files that no longer exist in the current checkout. A stale
# plan would otherwise burn all three automouse attempts as a poison pill.
#
# Token resolution mirrors bin/check-docs::scanReferences() (PHP), reimplemented
# in Bash since check-docs is not callable for a single out-of-repo plan file:
#   - tokens come from markdown links `[...](target)` and backtick spans `...`
#   - the part before the first '#', '?', or whitespace is kept
#   - only tokens prefixed bin/ ibl5/ .claude/ .github/ are repo paths
#   - glob/placeholder metacharacters and non-charset tokens are skipped
#   - survivors are de-duplicated and tested with [ -e "$REPO_ROOT/$token" ]
#
# Two STRUCTURAL exemptions precede extraction (see the awk pass below): tokens
# inside fenced code blocks and tokens under non-dependency headings (Out of
# Scope / Non-Goals / Rejected / Alternatives) are dropped, because paths there
# are illustrative or explicitly-not-touched, never dependencies the impl reads.
#
# Exit codes: 0 = all tokens resolve (or none), 1 = stale (unresolved tokens
# printed as "STALE: <token>"), 2 = usage error / plan file missing.
#
# Bash 3.2 / macOS compatible: no mapfile, no declare -A; temp files collect
# tokens. The `shell=bash` directive above keeps shellcheck's SC3xxx
# (sh-dialect) warnings from firing on the intentional bashisms.

set -u

usage() {
    echo "Usage: bin/check-plan-staleness <plan-file>" >&2
}

PLAN_FILE="${1:-}"
if [ -z "$PLAN_FILE" ] || [ ! -e "$PLAN_FILE" ]; then
    usage
    exit 2
fi

# Resolve the repo root from THIS SCRIPT's own location — never from the plan
# file (which lives outside the repo) or the cwd. Walk up until a .git dir/file
# is found. This is the load-bearing correctness point: resolving tokens
# relative to the out-of-repo plan file would mark every token unresolved.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$SCRIPT_DIR"
while [ "$REPO_ROOT" != "/" ] && [ ! -e "$REPO_ROOT/.git" ]; do
    REPO_ROOT="$(dirname "$REPO_ROOT")"
done
if [ "$REPO_ROOT" = "/" ]; then
    echo "error: could not locate repo root" >&2
    exit 2
fi

TOKENS_FILE="$(mktemp)"
SEEN_FILE="$(mktemp)"
MISSING_FILE="$(mktemp)"
SCAN_FILE="$(mktemp)"
trap 'rm -f "$TOKENS_FILE" "$SEEN_FILE" "$MISSING_FILE" "$SCAN_FILE"' EXIT

# Structural exemption pass. Before extracting tokens, drop plan regions that by
# construction never carry a real path *dependency* the implementation reads:
#
#   1. Fenced code blocks (``` … ```) — illustrative snippets. Plan authors put
#      example assertions and shell recipes here, often referencing deliberately
#      non-existent paths (e.g. a regression test's `GoneForever.php` literal).
#      The token-extraction grep is line-based and fence-blind, so without this
#      those literals get flagged stale (recurring FP class — see report 8 of the
#      2026-07-05 skip audit).
#   2. Non-dependency sections — headings matching Out of Scope / Non-Goals /
#      Rejected / Alternatives. Paths named there are things the plan explicitly
#      does NOT touch, or files another PR creates, discussed for context. They
#      are not dependencies, so their on-disk absence cannot poison a run (the FP
#      that skipped discord-pipeline-1: `bin/bug-pipeline-cron-setup`, a file PR
#      #5a creates, cited under `## Out of Scope`). Heading level is tracked so a
#      subsection stays exempt until a sibling/ancestor heading closes it.
#
# This is deliberately narrow: the guard's whole job is catching a vanished
# dependency, so IN-scope sections (Critical Files, phase bodies, Verification
# Matrix) are still scanned in full and the same-line creation-cue logic below
# still handles to-be-created paths there. Authoring convention that keeps
# not-yet-existing paths in an exempt position lives in .claude/skills/plan.
#
# Known limitation: an UNCLOSED fence (odd number of ``` markers) leaves in_fence
# toggled on to EOF, silently exempting every path below the last opener. Low risk
# — an unbalanced fence also breaks markdown rendering, so it surfaces elsewhere —
# but it is the one over-exemption path (a genuinely stale dependency below the
# stray opener would be masked). Kept simple over adding a balance check.
awk '
    BEGIN { in_fence = 0; exempt_level = 0 }
    /^[[:space:]]*```/ { in_fence = !in_fence; next }
    in_fence { next }
    /^#+[[:space:]]/ {
        lvl = 0
        while (substr($0, lvl + 1, 1) == "#") lvl++
        htext = tolower($0)
        # Match only when the section TITLE LEADS with a non-dependency keyword
        # (anchored after the #s), so "## Rejected Alternatives" / "## Out of
        # Scope" exempt but "## Trade-offs (rejected paths noted)" does not.
        is_exempt = (htext ~ /^#+[[:space:]]+(out[ -]of[ -]scope|non-?goals?|rejected|alternatives?)/)
        if (exempt_level > 0 && lvl <= exempt_level) exempt_level = 0
        if (exempt_level == 0 && is_exempt) exempt_level = lvl
        if (exempt_level > 0) next
        print
        next
    }
    exempt_level > 0 { next }
    { print }
' "$PLAN_FILE" > "$SCAN_FILE"

# Collect candidate tokens from the filtered scan file (fences and non-dependency
# sections already removed above). Markdown link targets and backtick-span
# contents are extracted, then the surrounding syntax is stripped. A no-match
# grep exits 1 harmlessly (no `set -e`).
{
    grep -oE '\[[^]]*\]\([^)[:space:]]+\)' "$SCAN_FILE" | sed -E 's/^\[[^]]*\]\(//; s/\)$//'
    # shellcheck disable=SC2016  # backticks are literal markdown-span delimiters, not command substitution
    grep -oE '`[^`]+`' "$SCAN_FILE" | sed -E 's/^`//; s/`$//'
} >> "$TOKENS_FILE"

while IFS= read -r token; do
    # Keep only the part before the first '#', '?', or whitespace.
    token="$(printf '%s' "$token" | sed -E 's/[[:space:]#?].*$//')"
    [ -n "$token" ] || continue

    # Only the four in-scope repo-path prefixes (narrower than check-docs).
    case "$token" in
        bin/*|ibl5/*|.claude/*|.github/*) : ;;
        *) continue ;;
    esac

    # Skip glob/placeholder metacharacters (this also drops `<placeholder>`).
    case "$token" in
        *[\*\?\[\]\{\}\<\>]*) continue ;;
    esac

    # Skip ellipsis placeholders. `ibl5/...` is meta-notation meaning "some real
    # path" (e.g. a plan line explaining that backtick path refs resolve), not a
    # path the plan depends on. No real repo path contains `...`, but the charset
    # check below passes '.' so without this guard the ellipsis is tested as a
    # literal path and always flagged stale (false positive).
    case "$token" in
        *...*) continue ;;
    esac

    # Skip new-ADR numeric placeholders. A plan that will create an ADR cites it
    # at a placeholder path like `ibl5/docs/decisions/00NN-slug.md` — the number
    # is assigned at impl time by bin/next-adr. Real ADR files use digits only in
    # the number slot and lowercase-kebab slugs, so an uppercase "NN" in a
    # docs/decisions path is always a placeholder, never a dependency the plan
    # reads. (Recurring FP class A — e.g. plan pr-triage-gated-auto-arm.) The
    # case is case-sensitive, so a real ADR like 0069-foo.md never matches.
    case "$token" in
        *docs/decisions/*NN*) continue ;;
    esac

    # Validate charset; this also drops `$VAR/...` shell-variable tokens.
    if ! printf '%s' "$token" | grep -qE '^[A-Za-z0-9._/-]+$'; then
        continue
    fi

    # De-duplicate.
    if grep -qxF "$token" "$SEEN_FILE"; then
        continue
    fi
    printf '%s\n' "$token" >> "$SEEN_FILE"

    # A token resolves if it exists at the repo root. For bare bin/ tokens it
    # also resolves at ibl5/bin/ — CI runs those scripts under
    # `working-directory: ibl5`, so plans reference them in the bare bin/ form
    # (e.g. `bin/check-baseline-drift`) even though the file is ibl5/bin/<x>.
    if [ -e "$REPO_ROOT/$token" ]; then
        continue
    fi
    case "$token" in
        bin/*)
            if [ -e "$REPO_ROOT/ibl5/$token" ]; then
                continue
            fi
            ;;
    esac

    # Not on disk. Before flagging it stale, check whether the plan references
    # this token in a CREATION context — a file the plan itself creates is not a
    # poison-pill stale path. The guard catches renamed/moved/deleted paths, not
    # to-be-created ones. We require the creation cue to appear on a line that
    # also contains the token (same-line), so a "Create X" elsewhere can't mask
    # a genuinely stale Y. `post-impl` is the verification-matrix timing column
    # for new artifacts; `pre-impl` rows reference existing files (which resolve
    # on disk and never reach here).
    if grep -F -- "$token" "$SCAN_FILE" \
        | grep -qE '([Cc]reate|[Nn]ew file|[Aa]dd(s|ing)? (a )?new|[Ii]ntroduce|[Ss]caffold|[Ww]rite|\*\*[Nn][Ee][Ww]\*\*|[-—] *NEW\b|\b[Mm]ov(e|ed|es|ing)\b|\b[Rr]ename(d|s|ing)?\b|\b[Rr]elocat(e|ed|es|ing)\b|→|[Rr]eject(ed)?|[Ff]ixture|throwaway|scratch|post-impl)'; then
        continue
    fi

    printf '%s\n' "$token" >> "$MISSING_FILE"
done < "$TOKENS_FILE"

if [ -s "$MISSING_FILE" ]; then
    while IFS= read -r m; do
        echo "STALE: $m"
    done < "$MISSING_FILE"
    exit 1
fi

exit 0
