#!/bin/bash
# Lists files in classes/ over THRESHOLD lines. With --pr, lists only classes
# that CROSSED THRESHOLD in this PR: <= THRESHOLD at the base commit and now
# > THRESHOLD at head. Chronic already-over-THRESHOLD files are not reported.
set -euo pipefail

THRESHOLD=${HOT_FILE_THRESHOLD:-500}
BASE_REF=${HOT_FILE_BASE_REF:-origin/master}
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT/ibl5"

echo "=== Hot files (> $THRESHOLD LOC) ==="
find classes -name '*.php' -exec wc -l {} \; | \
  awk -v t="$THRESHOLD" '$1 > t { printf "%6d %s\n", $1, $2 }' | sort -rn

if [ "${1:-}" = "--pr" ]; then
    crossed=0
    # Iterate the class files this PR touched.
    while read -r file; do
        [ -z "$file" ] && continue
        head_loc=$(wc -l < "$ROOT/$file" 2>/dev/null || echo 0)
        head_loc=$(echo "$head_loc" | tr -d ' ')
        # File deleted at head (or unreadable) cannot be a crossing.
        [ "$head_loc" -gt "$THRESHOLD" ] || continue
        # Base LOC: a path absent at base (new/renamed) resolves to 0 -> crossing.
        # Guard the assignment: `git show` exits non-zero for an absent path and
        # pipefail would otherwise abort under `set -e` before the default runs.
        base_loc=$(git show "$BASE_REF:$file" 2>/dev/null | wc -l | tr -d ' ') || base_loc=0
        base_loc=${base_loc:-0}
        if [ "$base_loc" -le "$THRESHOLD" ]; then
            if [ "$crossed" = "0" ]; then
                echo "=== Classes that crossed $THRESHOLD LOC in this PR ==="
            fi
            echo "CROSSED: $file (now $head_loc LOC, was $base_loc at base)"
            crossed=1
        fi
    # :(glob) so ** matches zero-or-more path segments, covering both nested
    # (classes/Foo/Foo.php) and top-level (classes/Foo.php) class files —
    # matching the bare snapshot's `find classes` scope above.
    done < <(git diff --name-only "$BASE_REF" -- ':(glob)classes/**/*.php')
    # Exit status encodes the signal the workflow branches on:
    #   0 = at least one crossing (post the comment)
    #   1 = no crossing (delete any stale comment)
    [ "$crossed" = "1" ]
fi
