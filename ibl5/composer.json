{
    "require": {
        "php": "^8.1",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.4",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "classes/"
        }
    },
    "scripts": {
        "lint:php": "vendor/bin/phpcs --standard=PSR12 src",
        "lint:php:fix": "vendor/bin/phpcbf --standard=PSR12 src",
        "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon --memory-limit=1G",
        "analyse:baseline": "vendor/bin/phpstan analyse --configuration=phpstan.neon --generate-baseline --memory-limit=1G"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
