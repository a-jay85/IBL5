#!/usr/bin/env bash
# shellcheck shell=bash
#
# bin/regen-schema-dump — dump the CURRENT database schema to a byte-stable
# reference artifact at ibl5/docs/schema/current-schema.sql.
#
# The "current schema" = 000_baseline_schema.sql + every numbered migration.
# This script connects to an already-migrated MariaDB (all migrations applied),
# dumps all tables + views (no data, no triggers, no `migrations` bookkeeping),
# NORMALIZES the output so it is byte-identical across runs, and writes it with
# an auto-generated header.
#
# Invoked identically by CI (.github/workflows/migration-safety.yml, on master
# push) and by the in-PR initial commit, so the committed artifact and CI's
# regenerated artifact are byte-identical (modulo a possible client-version
# delta that self-heals in one commit).
#
# Usage: bin/regen-schema-dump [-h HOST] [-u USER] [-p PASS] [-d DB]
#   -h HOST  MariaDB host           (default 127.0.0.1)
#   -u USER  MariaDB user           (default root)
#   -p PASS  MariaDB password       (default root)
#   -d DB    scratch DB name        (default ibl5_schema)
#
# NOTE: uses the `mysqldump` binary (NOT the `mariadb`/`mariadb-dump` alias) on
# purpose — the host-mariadb-guard CI check (tests.yml) greps for a bare
# `mariadb` client invocation in bin/ scripts; switching to that alias would
# trip it. Do not "modernize" the binary name.
set -euo pipefail

HOST=127.0.0.1
USER=root
PASS=root
DB=ibl5_schema

usage() {
    echo "Usage: bin/regen-schema-dump [-h HOST] [-u USER] [-p PASS] [-d DB]" >&2
    exit 2
}

while getopts h:u:p:d: opt; do
    case "$opt" in
        h) HOST="$OPTARG" ;;
        u) USER="$OPTARG" ;;
        p) PASS="$OPTARG" ;;
        d) DB="$OPTARG" ;;
        *) usage ;;
    esac
done

command -v mysqldump >/dev/null 2>&1 || {
    echo "ERROR: mysqldump not found on PATH." >&2
    exit 1
}

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUT="$ROOT/ibl5/docs/schema/current-schema.sql"
mkdir -p "$ROOT/ibl5/docs/schema"

# Dump + normalize. Each flag/filter defends byte-determinism:
#   --no-data        schema only, never row data
#   --skip-comments  strips mysqldump's header AND the trailing dated
#                    "-- Dump completed on <date>" line (the biggest churn source)
#   --skip-triggers  triggers are behavior, not schema-reference surface
#   --ignore-table   the migrations bookkeeping table's rows/AUTO_INCREMENT are noise
#   --no-create-db   no CREATE DATABASE/USE line; keeps the artifact DB-name-agnostic
# The three seds strip the remaining run-/DB-specific churn:
#   DEFINER=`x`@`y`      carried by VIEW definitions
#   AUTO_INCREMENT=<n>   per-table counter that drifts on every insert
#   `<db>`.              backtick-qualified DB prefix mysqldump embeds in VIEW bodies
mysqldump -h "$HOST" -u "$USER" -p"$PASS" \
    --no-data --no-create-db --skip-comments --skip-triggers \
    --ignore-table="$DB".migrations \
    "$DB" 2> >(grep -v 'Using a password' >&2) \
    | sed 's/DEFINER=`[^`]*`@`[^`]*`//g' \
    | sed -E 's/ AUTO_INCREMENT=[0-9]+//g' \
    | sed "s/\`$DB\`\.//g" \
    > "$OUT.tmp"

# Prepend a fixed, script-authored header (static, so it never churns; and
# because it is added AFTER --skip-comments, the dump step cannot strip it).
{
    printf -- '-- Auto-generated by bin/regen-schema-dump — do not edit.\n'
    printf -- '-- Current schema = 000_baseline_schema.sql + all numbered migrations.\n'
    printf -- '-- Regenerate: apply all migrations to a scratch DB, then run bin/regen-schema-dump.\n\n'
    cat "$OUT.tmp"
} > "$OUT"
rm -f "$OUT.tmp"

echo "Wrote $OUT"
