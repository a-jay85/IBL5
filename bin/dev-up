#!/bin/bash
# Boot the main Docker stack with a live production DB sync.
# Canonical local-dev entry point — uses bin/db-sync-prod to stream a full
# copy of production (including STORED-GENERATED-column tables like
# ibl_box_scores) into the ibl5-mariadb container.
#
# Usage: bin/dev-up

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

docker compose -f "$REPO_ROOT/docker-compose.yml" up -d --build

echo "Waiting for ibl5-mariadb to be ready..."
RETRIES=0
MAX_RETRIES=30
until docker exec ibl5-mariadb healthcheck.sh --connect --innodb_initialized &>/dev/null; do
    RETRIES=$((RETRIES + 1))
    if [ "$RETRIES" -ge "$MAX_RETRIES" ]; then
        echo "Error: ibl5-mariadb did not become healthy after ${MAX_RETRIES} attempts" >&2
        exit 1
    fi
    sleep 2
done
echo "MariaDB is ready."

if ! "$REPO_ROOT/bin/db-sync-prod"; then
    echo "Error: db-sync-prod failed. The stack is up but the database may be empty." >&2
    echo "  Fix REMOTE_* creds in $REPO_ROOT/.env and re-run: bin/db-sync-prod" >&2
    exit 1
fi

echo "Stack up at http://main.localhost/ibl5/"
