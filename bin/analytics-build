#!/bin/bash
# Full rebuild of the DuckDB analytics database.
# Idempotent: deletes and recreates from scratch every time.
#
# Usage: bin/analytics-build [--writeback] [--skip-export] [--local | --my-cnf]
#   --writeback    After building, export writeback CSVs and import to MariaDB
#   --skip-export  Skip the MariaDB → CSV export step (use existing CSVs)
#   --local        Force local Docker connection (ignore REMOTE_* in .env)
#   --my-cnf       Use ~/.my.cnf for credentials (for running on prod, where
#                  neither root/root local Docker nor REMOTE_* in .env applies)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
ANALYTICS_DIR="$REPO_ROOT/ibl5/analytics"
DATA_DIR="$ANALYTICS_DIR/data"
DB_FILE="$DATA_DIR/ibl_analytics.duckdb"
DUCKDB="$ANALYTICS_DIR/duckdb"

WRITEBACK=false
SKIP_EXPORT=false
FORCE_LOCAL=false
USE_MY_CNF=false

for arg in "$@"; do
    case "$arg" in
        --writeback)   WRITEBACK=true ;;
        --skip-export) SKIP_EXPORT=true ;;
        --local)       FORCE_LOCAL=true ;;
        --my-cnf)      USE_MY_CNF=true ;;
        *)             echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

if [ "$USE_MY_CNF" = true ] && [ "$FORCE_LOCAL" = true ]; then
    echo "Error: --my-cnf and --local are mutually exclusive" >&2
    exit 1
fi

# Verify DuckDB binary exists
if [ ! -x "$DUCKDB" ]; then
    echo "DuckDB binary not found at $DUCKDB" >&2
    echo "Run: bin/analytics-setup" >&2
    exit 1
fi

START_TIME=$(date +%s)

# Step 1: Export MariaDB → CSV
if [ "$SKIP_EXPORT" = false ]; then
    echo "=== Step 1: Exporting MariaDB → CSV ==="
    EXPORT_ARGS=""
    if [ "$FORCE_LOCAL" = true ]; then
        EXPORT_ARGS="--local"
    elif [ "$USE_MY_CNF" = true ]; then
        EXPORT_ARGS="--my-cnf"
    fi
    # shellcheck disable=SC2086
    "$REPO_ROOT/bin/analytics-export" $EXPORT_ARGS
else
    echo "=== Step 1: Skipping export (using existing CSVs) ==="
fi

# Step 2: Delete existing DuckDB file
echo ""
echo "=== Step 2: Creating fresh DuckDB database ==="
rm -f "$DB_FILE" "$DB_FILE.wal"

# Step 3: Run schema files in order (from the data directory so relative paths work)
cd "$ANALYTICS_DIR"

echo ""
echo "=== Step 3: Building dimension tables ==="
"$DUCKDB" "$DB_FILE" < schema/01_dimensions.sql

echo ""
echo "=== Step 4: Building fact tables ==="
"$DUCKDB" "$DB_FILE" < schema/02_facts.sql

echo ""
echo "=== Step 5: Building aggregate tables ==="
"$DUCKDB" "$DB_FILE" < schema/03_aggregates.sql

echo ""
echo "=== Step 6: Running validation ==="
"$DUCKDB" "$DB_FILE" < schema/04_validation.sql

# Step 7: Summary
END_TIME=$(date +%s)
ELAPSED=$((END_TIME - START_TIME))
DB_SIZE=$(du -h "$DB_FILE" | cut -f1)

echo ""
echo "=== Build Summary ==="
echo "Database: $DB_FILE ($DB_SIZE)"
echo "Elapsed: ${ELAPSED}s"
echo ""

# Print table row counts
"$DUCKDB" "$DB_FILE" -c "
SELECT table_name, estimated_size
FROM duckdb_tables()
WHERE schema_name = 'main'
ORDER BY table_name;
"

# Step 8: Optional write-back
if [ "$WRITEBACK" = true ]; then
    echo ""
    echo "=== Step 8: Write-back to MariaDB ==="

    mkdir -p "$DATA_DIR/writeback"

    # Export tsi_bands
    "$DUCKDB" "$DB_FILE" -c "
    COPY (
        SELECT
            pid, season_year, tsi_sum, tsi_band,
            delta_r_2gp, delta_r_ftp, delta_r_ast,
            age_relative_to_peak
        FROM agg_tsi_progression
    ) TO '$DATA_DIR/writeback/tsi_bands.csv' (HEADER, DELIMITER ',');
    "

    # Export player_peaks
    "$DUCKDB" "$DB_FILE" -c "
    COPY (
        SELECT
            pid, peak_season_year, peak_ppg,
            career_ppg, career_seasons
        FROM agg_player_career
        WHERE peak_season_year IS NOT NULL
    ) TO '$DATA_DIR/writeback/player_peaks.csv' (HEADER, DELIMITER ',');
    "

    echo "Write-back CSVs exported to $DATA_DIR/writeback/"

    # Run PHP write-back script
    if [ -f "$REPO_ROOT/ibl5/scripts/analyticsWriteback.php" ]; then
        php "$REPO_ROOT/ibl5/scripts/analyticsWriteback.php"
    else
        echo "Warning: analyticsWriteback.php not found, skipping MariaDB import"
    fi
fi

echo ""
echo "Done. Interactive queries:"
echo "  $DUCKDB $DB_FILE"
echo "  $DUCKDB $DB_FILE < analytics/queries/tsi_progression.sql"
