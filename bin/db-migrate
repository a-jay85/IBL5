#!/bin/bash
# Run pending SQL migrations against a running Docker MariaDB container.
# Usage: bin/db-migrate <db-container> <migrations-dir>
#
# Migrations are tracked in schema_migrations(version VARCHAR(255) PRIMARY KEY).
# Already-applied migrations are skipped (idempotent).

set -euo pipefail

DB_CONTAINER="${1:-}"
MIGRATIONS_DIR="${2:-}"

if [ -z "$DB_CONTAINER" ] || [ -z "$MIGRATIONS_DIR" ]; then
    echo "Usage: bin/db-migrate <db-container> <migrations-dir>" >&2
    exit 1
fi

if [ ! -d "$MIGRATIONS_DIR" ]; then
    echo "Migrations directory not found: $MIGRATIONS_DIR" >&2
    exit 1
fi

# Check there are actually .sql files
if ! ls "$MIGRATIONS_DIR"/*.sql &>/dev/null; then
    echo "No .sql files found in $MIGRATIONS_DIR"
    exit 0
fi

DB_CMD="mariadb -u root -proot iblhoops_ibl5"

# Wrapper to suppress MariaDB "password on command line" warning
db_exec() {
    docker exec "$@" 2>&1 | grep -v '\[Warning\].*password' || true
}
db_exec_stdin() {
    docker exec -i "$@" 2>&1 | grep -v '\[Warning\].*password' || true
}

echo "Running migrations..."
db_exec "$DB_CONTAINER" $DB_CMD \
    -e "CREATE TABLE IF NOT EXISTS schema_migrations (version VARCHAR(255) PRIMARY KEY, applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);"

for migration in "$MIGRATIONS_DIR"/*.sql; do
    [ -f "$migration" ] || continue
    BASENAME=$(basename "$migration")
    ALREADY=$(db_exec "$DB_CONTAINER" $DB_CMD -N \
        -e "SELECT COUNT(*) FROM schema_migrations WHERE version='$BASENAME';")
    if [ "$ALREADY" = "0" ]; then
        echo "  Applying $BASENAME..."
        db_exec_stdin "$DB_CONTAINER" $DB_CMD < "$migration"
        db_exec "$DB_CONTAINER" $DB_CMD \
            -e "INSERT INTO schema_migrations (version) VALUES ('$BASENAME');"
    fi
done
