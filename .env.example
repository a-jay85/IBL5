# Environment variables for IBL5 development
# Copy to .env and fill in real values: cp .env.example .env

# Docker Compose (app DB user created by MariaDB entrypoint)
DB_USER=your_db_user
DB_PASS=your_db_password

# Production Database (direct connection for bin/analytics-build)
REMOTE_HOST=your_production_host
REMOTE_PORT=3306
REMOTE_USER=your_db_user
REMOTE_PASSWORD=your_db_password
REMOTE_DATABASE=iblhoops_ibl5

# Production SSH (used by bin/sim-files-update)
PROD_SSH_HOST=user@your_production_host
