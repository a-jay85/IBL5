#!/bin/bash
# Sync production database directly into a running Docker MariaDB container.
# Streams mariadb-dump → docker exec stdin (no intermediate file).
#
# This is the canonical seed path for local dev: bin/dev-up (main stack)
# and bin/wt-up --prod (worktrees) both invoke it. Handles STORED GENERATED
# tables like ibl_box_scores via dedicated --no-create-info passes.
#
# Usage: bin/db-sync-prod [worktree-name]
#
# Target resolution (in order):
#   1. <worktree-name> argument → <WT_PARENT>/<name>/.wt-slug
#   2. CWD inside <WT_PARENT>/<name>/... → that worktree
#   3. No argument, not in worktree → main ibl5-mariadb container
#
# Worktrees live OUTSIDE the repo (ADR-0046); WT_PARENT is resolved via the
# worktrees_parent_dir helper. A legacy in-repo path is kept as a fallback for
# pre-migration worktrees, mirroring bin/db-test-up.
#
# Prereqs: .env with REMOTE_* creds; target container already running.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
source "$REPO_ROOT/bin/lib/db-helpers.sh"
source "$REPO_ROOT/bin/lib/git-helpers.sh"
WT_PARENT="$(worktrees_parent_dir "$REPO_ROOT")"

# The mariadb client is keg-only under Homebrew (the formula is NOT linked into
# /opt/homebrew/bin), so a non-login shell — e.g. the one bin/wt-up spawns — can
# have it installed yet absent from PATH (`line NNN: mariadb: command not found`).
# Prepend the known keg dirs (Apple Silicon + Intel prefixes) so the host client
# resolves regardless of the invoking shell's PATH. Only prepend until found, so
# an already-on-PATH client is respected.
for _kegbin in \
    /opt/homebrew/opt/mariadb/bin \
    /opt/homebrew/opt/mysql-client/bin \
    /opt/homebrew/opt/mysql/bin \
    /usr/local/opt/mariadb/bin \
    /usr/local/opt/mysql-client/bin; do
    if ! command -v mariadb-dump >/dev/null 2>&1 && [ -x "$_kegbin/mariadb-dump" ]; then
        PATH="$_kegbin:$PATH"
    fi
done
unset _kegbin
if ! command -v mariadb >/dev/null 2>&1 || ! command -v mariadb-dump >/dev/null 2>&1; then
    echo "Error: mariadb client not found on PATH (need both 'mariadb' and 'mariadb-dump')." >&2
    echo "  Install it:  brew install mariadb" >&2
    echo "  It's keg-only — db-sync-prod adds /opt/homebrew/opt/mariadb/bin to PATH automatically once installed." >&2
    exit 1
fi

WORKTREE_ARG="${1:-}"

# Load .env for REMOTE_* creds.
# When invoked from a worktree's bin/, REPO_ROOT is the worktree root, which
# has no .env (only the main worktree does). Fall back to the main worktree
# in that case so `bin/wt-up --prod` works from any CWD.
ENV_FILE="$REPO_ROOT/.env"
if [ ! -f "$ENV_FILE" ]; then
    MAIN_WT="$(git -C "$REPO_ROOT" worktree list --porcelain 2>/dev/null | awk '/^worktree / {print $2; exit}')"
    if [ -n "$MAIN_WT" ] && [ -f "$MAIN_WT/.env" ]; then
        ENV_FILE="$MAIN_WT/.env"
    else
        echo "Error: $REPO_ROOT/.env not found — REMOTE_* credentials required." >&2
        exit 1
    fi
fi
set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

if [ -z "${REMOTE_HOST:-}" ] || [ "$REMOTE_HOST" = "localhost" ] || [ "$REMOTE_HOST" = "127.0.0.1" ]; then
    echo "Error: REMOTE_HOST must point to production (got: ${REMOTE_HOST:-<unset>})." >&2
    exit 1
fi

REMOTE_PORT="${REMOTE_PORT:-3306}"
REMOTE_DATABASE="${REMOTE_DATABASE:-iblhoops_ibl5}"

# Resolve target slug + worktree path
SLUG=""
WORKTREE_PATH=""

resolve_from_wt_name() {
    local name="$1"
    local wt_path="$WT_PARENT/$name"
    if [ ! -d "$wt_path" ]; then
        wt_path="$REPO_ROOT/worktrees/$name"  # legacy fallback (pre-migration)
    fi
    local slug_file="$wt_path/.wt-slug"
    if [ ! -f "$slug_file" ]; then
        return 1
    fi
    SLUG="$(cat "$slug_file")"
    WORKTREE_PATH="$wt_path"
}

if [ -n "$WORKTREE_ARG" ]; then
    if ! resolve_from_wt_name "$WORKTREE_ARG"; then
        echo "Error: No worktree named '$WORKTREE_ARG' (missing $WT_PARENT/$WORKTREE_ARG/.wt-slug)." >&2
        echo "Start it first: bin/wt-up $WORKTREE_ARG" >&2
        exit 1
    fi
elif [[ "$PWD" == "$WT_PARENT/"* || "$PWD" == "$REPO_ROOT/worktrees/"* ]]; then
    if [[ "$PWD" == "$WT_PARENT/"* ]]; then
        wt_rel="${PWD#"$WT_PARENT/"}"
    else
        wt_rel="${PWD#"$REPO_ROOT/worktrees/"}"  # legacy fallback (pre-migration)
    fi
    wt_name="${wt_rel%%/*}"
    if ! resolve_from_wt_name "$wt_name"; then
        echo "Error: CWD is in worktree '$wt_name' but .wt-slug is missing. Start it: bin/wt-up $wt_name" >&2
        exit 1
    fi
else
    # Default: main Docker stack container
    SLUG=""
    WORKTREE_PATH="$REPO_ROOT"
fi

if [ -n "$SLUG" ]; then
    DB_CONTAINER="ibl5-db-$SLUG"
else
    DB_CONTAINER="ibl5-mariadb"
fi

if ! docker ps --format '{{.Names}}' | grep -q "^${DB_CONTAINER}$"; then
    echo "Error: Container $DB_CONTAINER is not running." >&2
    if [ -n "$SLUG" ]; then
        echo "Start it: bin/wt-up <worktree-name>" >&2
    else
        echo "Start it: docker compose up -d" >&2
    fi
    exit 1
fi

echo "=== DB Sync: Production → $DB_CONTAINER ==="
echo "  Source: $REMOTE_HOST:$REMOTE_PORT/$REMOTE_DATABASE"
echo "  Target: $DB_CONTAINER"
[ -n "$WORKTREE_PATH" ] && echo "  Worktree: $WORKTREE_PATH"
echo ""

remote_query() {
    MYSQL_PWD="$REMOTE_PASSWORD" mariadb \
        -h "$REMOTE_HOST" -P "$REMOTE_PORT" --skip-ssl --compress \
        -u "$REMOTE_USER" "$REMOTE_DATABASE" -N -B -e "$1"
}

remote_dump() {
    MYSQL_PWD="$REMOTE_PASSWORD" mariadb-dump \
        -h "$REMOTE_HOST" -P "$REMOTE_PORT" \
        -u "$REMOTE_USER" \
        --skip-ssl --compress --single-transaction --skip-lock-tables \
        "$@"
}

# Detect STORED GENERATED column tables — their data needs dedicated column-list
# INSERTs (mariadb-dump emits those with --no-create-info) to avoid ERROR 1906.
GENERATED_TABLES=$(remote_query "
    SELECT DISTINCT table_name
    FROM information_schema.columns
    WHERE table_schema='$REMOTE_DATABASE'
      AND extra LIKE '%GENERATED%'
    ORDER BY table_name;
")

# Fetch real tables (not views) in one round trip
ALL_TABLES=$(remote_query "
    SELECT table_name
    FROM information_schema.tables
    WHERE table_schema='$REMOTE_DATABASE'
      AND engine IS NOT NULL
    ORDER BY table_name;
")

GEN_RE=""
for t in $GENERATED_TABLES; do
    GEN_RE="${GEN_RE:+$GEN_RE|}$t"
done

REGULAR_TABLES=""
for name in $ALL_TABLES; do
    if [ -n "$GEN_RE" ] && echo "$name" | grep -qE "^($GEN_RE)$"; then
        continue
    fi
    REGULAR_TABLES="$REGULAR_TABLES $name"
done

echo "Dumping prod → $DB_CONTAINER..."
if [ -n "$GENERATED_TABLES" ]; then
    echo "  Generated-column tables:$(printf ' %s' $GENERATED_TABLES)"
fi
echo ""

# Stream schema + data into the container via db_import_sql (handles FK checks,
# DEFINER stripping, and error filtering).
#
# Routines (stored procedures/functions) are dumped LAST, in a separate
# non-fatal pass — deliberately NOT folded into the schema step. mariadb-dump
# --routines issues `SHOW FUNCTION STATUS` against prod's mysql.proc, which can
# block indefinitely on a server-side table-level lock. When it lived in the
# schema step, a routine stall hung the whole stream *after* the DROP/CREATE
# TABLE statements had already streamed in — leaving the local DB with schema
# but zero data (every table, incl. ibl_box_scores, empty) and the run killed
# at exit 144. --max-statement-time makes any metadata stall fail fast
# server-side (no orphaned waiter thread); the separate pass means a routine
# stall can never tear the data load.
SCHEMA_TIMEOUT=120    # metadata-only queries (SHOW CREATE TABLE); generous bound
ROUTINES_TIMEOUT=30   # mysql.proc may be locked on prod — fail fast, stay non-fatal

TOTAL_STEPS=2
[ -n "$GENERATED_TABLES" ] && TOTAL_STEPS=3
STEP=0

{
    STEP=$((STEP + 1))
    echo "  [$STEP/$TOTAL_STEPS] Schema (tables, views, triggers)..." >&2
    remote_dump --triggers --no-data --max-statement-time="$SCHEMA_TIMEOUT" \
        "$REMOTE_DATABASE"

    STEP=$((STEP + 1))
    echo "  [$STEP/$TOTAL_STEPS] Table data..." >&2
    # shellcheck disable=SC2086
    remote_dump --no-create-info --skip-triggers --skip-add-locks \
        "$REMOTE_DATABASE" $REGULAR_TABLES

    if [ -n "$GENERATED_TABLES" ]; then
        STEP=$((STEP + 1))
        echo "  [$STEP/$TOTAL_STEPS] Generated-column table data..." >&2
        # shellcheck disable=SC2086
        remote_dump --no-create-info --skip-triggers --skip-add-locks \
            "$REMOTE_DATABASE" $GENERATED_TABLES
    fi
} | db_import_sql "$DB_CONTAINER" || exit 1

# Routines pass: separate, time-bounded, non-fatal. --no-create-info/--no-data
# emit neither DROP nor CREATE TABLE, so a stall or timeout here leaves the
# already-loaded schema + data fully intact.
echo "  Routines (stored procedures/functions)..." >&2
if ! remote_dump --routines --no-create-info --no-data --skip-triggers \
        --max-statement-time="$ROUTINES_TIMEOUT" "$REMOTE_DATABASE" \
        | db_import_sql "$DB_CONTAINER"; then
    echo "  WARNING: routines dump failed or timed out (prod mysql.proc may be" >&2
    echo "           locked); schema + data loaded OK, routines skipped." >&2
fi

echo ""
echo "Backfilling schema_migrations from prod dump..."
docker exec "$DB_CONTAINER" mariadb -uroot -proot iblhoops_ibl5 -e "
    CREATE TABLE IF NOT EXISTS schema_migrations (
        version VARCHAR(255) PRIMARY KEY,
        applied_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    );
    INSERT IGNORE INTO schema_migrations (version)
        SELECT migration FROM migrations WHERE migration LIKE '%.sql';
" 2> >(db_strip_warnings >&2) || true

if [ -n "$WORKTREE_PATH" ] && [ -d "$WORKTREE_PATH/ibl5/migrations" ]; then
    echo ""
    echo "Replaying migrations not yet applied to prod..."
    "$REPO_ROOT/bin/db-migrate" "$DB_CONTAINER" "$WORKTREE_PATH/ibl5/migrations"
fi

# Verify row counts on a couple of canonical tables
echo ""
echo "=== Sync Complete ==="
docker exec "$DB_CONTAINER" mariadb -uroot -proot iblhoops_ibl5 -N -B -e "
SELECT CONCAT('  ibl_team_info:        ', COUNT(*), ' rows') FROM ibl_team_info;
SELECT CONCAT('  ibl_plr:              ', COUNT(*), ' rows') FROM ibl_plr;
SELECT CONCAT('  ibl_box_scores:       ', COUNT(*), ' rows') FROM ibl_box_scores;
SELECT CONCAT('  ibl_box_scores_teams: ', COUNT(*), ' rows') FROM ibl_box_scores_teams;
" 2> >(db_strip_warnings >&2) || true
