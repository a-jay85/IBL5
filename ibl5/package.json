{
  "name": "ibl5-design",
  "version": "1.0.0",
  "description": "IBL5 Design System with Tailwind CSS 4",
  "type": "module",
  "scripts": {
    "css:watch": "bunx @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css --watch",
    "css:build": "bunx @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css --minify",
    "test:e2e": "bunx playwright test",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:isolated": "./bin/e2e-local.sh",
    "test:e2e:visual": "./bin/visual-regression.sh",
    "test:e2e:visual:update": "./bin/visual-regression.sh --update-snapshots",
    "docker:up": "cd .. && docker compose up -d",
    "docker:down": "cd .. && docker compose down",
    "docker:logs": "cd .. && docker compose logs -f php",
    "wt:up": "cd .. && bin/wt-up",
    "wt:down": "cd .. && bin/wt-down",
    "wt:list": "cd .. && bin/wt-list"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
