#!/bin/bash
# Start a Docker environment for a worktree with its own PHP-Apache + MariaDB.
# Usage: bin/wt-up <worktree-name> [--pr] [--seed] [--prod] [--no-data]

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
WORKTREE_NAME=""
USE_PR=false
SEED_DB=false
PROD_DB=false
NO_DATA=false

# Wrapper to suppress MariaDB "password on command line" warning
db_exec() {
    docker exec "$@" 2>&1 | grep -v '\[Warning\].*password' || true
}
db_exec_stdin() {
    docker exec -i "$@" 2>&1 | grep -v '\[Warning\].*password' || true
}

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --pr) USE_PR=true ;;
        --seed) SEED_DB=true ;;
        --prod) PROD_DB=true ;;
        --no-data) NO_DATA=true ;;
        -*) echo "Unknown option: $arg" >&2; exit 1 ;;
        *) WORKTREE_NAME="$arg" ;;
    esac
done

if [ -z "$WORKTREE_NAME" ]; then
    echo "Usage: bin/wt-up <worktree-name> [--pr] [--seed] [--prod] [--no-data]" >&2
    echo "" >&2
    echo "Options:" >&2
    echo "  --pr            Use PR number as URL slug (e.g., pr-42.localhost)" >&2
    echo "  --seed          Import ci-seed.sql for test data (schema + CI seed)" >&2
    echo "  --prod          Import prod-seed.sql data (default if no data flag given)" >&2
    echo "  --no-data       Schema only, no seed data" >&2
    echo "" >&2
    echo "The DB volume is always purged to ensure a clean database." >&2
    exit 1
fi

# Default to prod data if no data flag was explicitly set
if [ "$SEED_DB" = false ] && [ "$PROD_DB" = false ] && [ "$NO_DATA" = false ]; then
    PROD_DB=true
fi

WORKTREE_PATH="$REPO_ROOT/worktrees/$WORKTREE_NAME"
if [ ! -d "$WORKTREE_PATH" ]; then
    echo "Error: Worktree not found at $WORKTREE_PATH" >&2
    exit 1
fi

# Determine URL slug
# Sanitize slug: Docker project names can't contain slashes
SLUG="${WORKTREE_NAME//\//-}"
if [ "$USE_PR" = true ]; then
    if ! command -v gh &> /dev/null; then
        echo "Error: gh CLI required for --pr flag" >&2
        exit 1
    fi
    PR_NUMBER=$(cd "$WORKTREE_PATH" && gh pr view --json number -q .number 2>/dev/null || true)
    if [ -z "$PR_NUMBER" ]; then
        echo "Error: No PR found for branch in worktree '$WORKTREE_NAME'" >&2
        exit 1
    fi
    SLUG="pr-$PR_NUMBER"
fi

# Ensure external network exists
if ! docker network inspect ibl5-proxy &>/dev/null; then
    echo "Creating ibl5-proxy network..."
    docker network create ibl5-proxy
fi

# Ensure shared services are running (Traefik for routing, Mailpit for email capture)
NEED_SHARED=false
if ! docker ps --format '{{.Names}}' | grep -q '^ibl5-traefik$'; then
    NEED_SHARED=true
fi
if ! docker ps --format '{{.Names}}' | grep -q '^ibl5-mailpit$'; then
    NEED_SHARED=true
fi
if [ "$NEED_SHARED" = true ]; then
    echo "Starting shared services (Traefik, Mailpit)..."
    docker compose -f "$REPO_ROOT/docker-compose.yml" up -d \
        || echo "Warning: Could not start shared services. Start manually: docker compose up -d (from $REPO_ROOT)"
fi

# Ensure node_modules symlink exists for CSS tooling
NODE_MODULES="$WORKTREE_PATH/ibl5/node_modules"
if [ ! -d "$NODE_MODULES" ]; then
    ln -sf "$REPO_ROOT/ibl5/node_modules" "$NODE_MODULES"
fi

# Build CSS for the worktree
STYLE_CSS="$WORKTREE_PATH/ibl5/themes/IBL/style/style.css"
# Replace symlink with real file so Docker can mount the worktree cleanly
if [ -L "$STYLE_CSS" ]; then
    rm "$STYLE_CSS"
fi
# Resolve bunx path now — backgrounded subshells may not inherit PATH (e.g. ~/.bun/bin)
BUNX_PATH="$(command -v bunx)"
if [ -z "$BUNX_PATH" ]; then
    echo "Warning: bunx not found in PATH — skipping CSS build/watch"
fi

echo "Building CSS for worktree..."
(cd "$WORKTREE_PATH/ibl5" && "${BUNX_PATH:-bunx}" @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css 2>/dev/null) || true
# Fallback: copy from main repo if build failed or produced empty file
if [ ! -s "$STYLE_CSS" ]; then
    echo "CSS build failed or empty — copying from main repo..."
    cp "$REPO_ROOT/ibl5/themes/IBL/style/style.css" "$STYLE_CSS" 2>/dev/null || true
fi

# Kill any existing CSS watcher for this worktree
CSS_PID_FILE="$WORKTREE_PATH/.css-watch.pid"
if [ -f "$CSS_PID_FILE" ]; then
    OLD_PID=$(cat "$CSS_PID_FILE")
    kill "$OLD_PID" 2>/dev/null || true
    rm -f "$CSS_PID_FILE"
fi

# Start CSS watcher in background so source changes auto-rebuild.
# nohup + disown: prevent SIGHUP death when the calling terminal/shell exits.
# Absolute paths: no cd needed, avoids PATH/cwd issues in detached process.
echo "Starting CSS watcher..."
nohup "${BUNX_PATH:-bunx}" @tailwindcss/cli \
    -i "$WORKTREE_PATH/ibl5/design/input.css" \
    -o "$WORKTREE_PATH/ibl5/themes/IBL/style/style.css" \
    --watch=always \
    > "$WORKTREE_PATH/.css-watch.log" 2>&1 &
echo $! > "$CSS_PID_FILE"
disown

# Kill any existing browser-sync for this worktree (PID file or port squatter)
BS_PID_FILE="$WORKTREE_PATH/.bs-sync.pid"
if [ -f "$BS_PID_FILE" ]; then
    OLD_BS_PID=$(cat "$BS_PID_FILE")
    kill "$OLD_BS_PID" 2>/dev/null || true
    rm -f "$BS_PID_FILE"
fi

# Copy config.php into worktree (can't use bind mount — VirtioFS fails on nested mounts)
CONFIG_PHP="$WORKTREE_PATH/ibl5/config.php"
if [ ! -s "$CONFIG_PHP" ] || [ -L "$CONFIG_PHP" ]; then
    [ -L "$CONFIG_PHP" ] && rm "$CONFIG_PHP"
    cp "$REPO_ROOT/ibl5/config.php" "$CONFIG_PHP" 2>/dev/null || true
fi

# Use the static compose file with Docker Compose variable interpolation.
# No sed templating — ${SLUG}, ${WORKTREE_PATH}, ${REPO_ROOT} are exported as env vars.
COMPOSE_FILE="$REPO_ROOT/docker/worktree-compose.yml"

if [ ! -f "$COMPOSE_FILE" ]; then
    echo "Error: Compose file not found at $COMPOSE_FILE" >&2
    exit 1
fi

# Write slug to dotfile — used by wt-down and wt-list to identify the running environment
echo "$SLUG" > "$WORKTREE_PATH/.wt-slug"

# Export vars so Docker Compose interpolates them in the static compose file
export SLUG WORKTREE_PATH REPO_ROOT

echo "Starting environment for '$WORKTREE_NAME' (slug: $SLUG)..."
# --env-file points to the repo root's .env so ${DB_USER}/${DB_PASS} resolve correctly.
# Without this, docker compose looks for .env relative to the compose file (the worktree dir),
# which doesn't have one — causing MariaDB to skip creating the app DB user.
ENV_FILE_FLAG=""
if [ -f "$REPO_ROOT/.env" ]; then
    ENV_FILE_FLAG="--env-file $REPO_ROOT/.env"
fi

# Always tear down existing containers and purge the DB volume so each wt-up
# starts with a clean database. docker volume rm silently fails if a container
# (even a stopped one) still references the volume, so we must compose down first.
echo "Removing existing environment..."
docker compose -f "$COMPOSE_FILE" $ENV_FILE_FLAG -p "ibl5-$SLUG" down 2>/dev/null || true
echo "Purging DB volume..."
docker volume rm "ibl5-${SLUG}_db-data" 2>/dev/null || true

docker compose -f "$COMPOSE_FILE" $ENV_FILE_FLAG -p "ibl5-$SLUG" up -d --build

# Wait for MariaDB to be healthy
echo "Waiting for MariaDB (db-$SLUG) to be ready..."
RETRIES=0
MAX_RETRIES=30
until docker exec "ibl5-db-$SLUG" healthcheck.sh --connect --innodb_initialized &>/dev/null; do
    RETRIES=$((RETRIES + 1))
    if [ "$RETRIES" -ge "$MAX_RETRIES" ]; then
        echo "Error: MariaDB did not become healthy after ${MAX_RETRIES} attempts" >&2
        exit 1
    fi
    sleep 2
done
echo "MariaDB is ready."

DB_CONTAINER="ibl5-db-$SLUG"
DB_CMD="mariadb -u root -proot iblhoops_ibl5"

# Always run migrations first (idempotent — skips already-applied ones).
# This ensures the full schema exists before any data import, matching the
# CI pipeline order: baseline → migrations → seed data.
# For --prod, this is critical: if prod-seed.sql was exported data-only
# (missing CREATE TABLE statements), the tables must already exist.
"$REPO_ROOT/bin/db-migrate" "$DB_CONTAINER" "$WORKTREE_PATH/ibl5/migrations"

if [ "$PROD_DB" = true ]; then
    # --prod: overlay production data onto the migration-created schema.
    # If prod-seed.sql contains CREATE TABLE statements (well-formed export),
    # they harmlessly recreate existing tables. If it's data-only, the tables
    # already exist from migrations above.
    PROD_SEED="$REPO_ROOT/ibl5/fixtures/prod-seed.sql"
    if [ ! -f "$PROD_SEED" ]; then
        echo "prod-seed.sql not found — falling back to ci-seed.sql..."
        PROD_DB=false
        SEED_DB=true
    fi
fi

if [ "$PROD_DB" = true ]; then
    echo "Importing prod-seed.sql..."
    # Strip DEFINER clauses — prod exports contain DEFINER=user@host that may
    # not match the Docker MariaDB user, causing ERROR 1449 on import.
    sed 's/ DEFINER=[^ ]* / /g' "$PROD_SEED" | db_exec_stdin "$DB_CONTAINER" $DB_CMD

    # Backfill schema_migrations so future db-migrate runs skip already-applied ones.
    # The prod dump tracks applied migrations in 'migrations' (id, migration, batch),
    # but db-migrate uses 'schema_migrations' (version). Bridge the two.
    echo "Backfilling schema_migrations from prod dump..."
    db_exec "$DB_CONTAINER" $DB_CMD \
        -e "INSERT IGNORE INTO schema_migrations (version) SELECT migration FROM migrations;" 2>/dev/null || true
fi

# Optionally seed with CI test data (after migrations so renamed columns exist)
if [ "$SEED_DB" = true ]; then
    CI_SEED="$WORKTREE_PATH/ibl5/tests/e2e/fixtures/ci-seed.sql"
    if [ -f "$CI_SEED" ]; then
        echo "Importing ci-seed.sql..."
        db_exec_stdin "$DB_CONTAINER" $DB_CMD < "$CI_SEED"
    else
        echo "Warning: ci-seed.sql not found at $CI_SEED"
    fi
fi

# Validate schema integrity — catches migrations that were marked as applied
# (via prod-seed backfill) but whose DDL was never actually executed.
PHP_CONTAINER="ibl5-php-$SLUG"
echo "Validating schema integrity..."
RETRIES=0
MAX_RETRIES=15
until docker exec "$PHP_CONTAINER" php /var/www/html/ibl5/bin/validate-schema &>/dev/null; do
    RETRIES=$((RETRIES + 1))
    if [ "$RETRIES" -ge 2 ]; then
        # First retry was waiting for PHP container — now it's a real failure
        echo ""
        echo "  WARNING: Schema validation failed!"
        docker exec "$PHP_CONTAINER" php /var/www/html/ibl5/bin/validate-schema 2>&1 || true
        echo ""
        echo "  The prod-seed may predate migrations that the code depends on."
        echo "  Manually apply the missing migration."
        echo ""
        break
    fi
    sleep 2
done
if [ "$RETRIES" -lt 2 ]; then
    echo "Schema validation passed."
fi

# Start browser-sync on the host, proxying the worktree's Docker URL.
# Runs on a per-worktree port (3100+) to avoid collisions.
# Uses host-side file watching (native FSEvents) for reliable change detection.
# Port = 3000 + PR number (e.g., PR #533 → localhost:3533)
# so the URL is predictable from the PR number alone.
BS_PR_NUMBER=$(cd "$WORKTREE_PATH" && gh pr view --json number -q .number 2>/dev/null || true)
if [ -n "$BS_PR_NUMBER" ]; then
    BS_PORT=$((3000 + BS_PR_NUMBER))
else
    # No PR yet — fall back to hash-based port
    BS_PORT=$((3100 + $(echo "$SLUG" | cksum | cut -d' ' -f1) % 900))
fi
# Kill anything already holding this port (e.g., a stale bin/bs-start process)
PORT_PID=$(lsof -ti :"$BS_PORT" 2>/dev/null || true)
if [ -n "$PORT_PID" ]; then
    echo "Killing stale process on port $BS_PORT (PID $PORT_PID)..."
    kill $PORT_PID 2>/dev/null || true
    sleep 1
fi

echo "Starting browser-sync (port $BS_PORT)..."
WT_IBL5="$WORKTREE_PATH/ibl5"
(cd "$WT_IBL5" && exec bunx browser-sync start \
    --proxy "$SLUG.localhost" \
    --port "$BS_PORT" \
    --files "$WT_IBL5/themes/IBL/style/style.css,$WT_IBL5/classes/**/*.php,$WT_IBL5/modules/**/*.php" \
    --no-open --no-ui --no-ghost-mode) \
    > "$WORKTREE_PATH/.bs-sync.log" 2>&1 &
echo $! > "$BS_PID_FILE"

echo ""
echo "================================================"
echo "  Worktree environment ready!"
echo "================================================"
echo ""
echo "  URL:     http://$SLUG.localhost/ibl5/"
echo "  Sync:    http://localhost:$BS_PORT/ibl5/  (live reload)"
echo "  Adminer: http://localhost:8082 (server: ibl5-db-$SLUG)"
echo "  DB CLI:  docker exec -it $DB_CONTAINER $DB_CMD"
if [ -f "$CSS_PID_FILE" ]; then
    echo "  CSS:     Watcher running (PID $(cat "$CSS_PID_FILE"), log: .css-watch.log)"
fi
echo ""

# Safari warning
if [ "$(uname)" = "Darwin" ]; then
    echo "  Note: *.localhost auto-resolves in Chrome/Firefox."
    echo "  Safari users: add '127.0.0.1 $SLUG.localhost' to /etc/hosts."
    echo ""
fi
