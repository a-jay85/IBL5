#!/bin/bash
# Stop a worktree Docker environment and remove its volumes.
# Usage: bin/wt-down <worktree-name> [--force]
#        bin/wt-down --all [--force]

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
WORKTREE_NAME=""
ALL=false
FORCE=false

# Parse arguments
for arg in "$@"; do
    case "$arg" in
        --all) ALL=true ;;
        --force) FORCE=true ;;
        -*) echo "Unknown option: $arg" >&2; exit 1 ;;
        *) WORKTREE_NAME="$arg" ;;
    esac
done

# Check for uncommitted changes in a worktree directory.
# Returns 0 if clean or --force, 1 if dirty and should abort.
check_uncommitted() {
    local wt_path="$1"
    local wt_name
    wt_name=$(basename "$wt_path")

    if [ "$FORCE" = true ]; then
        return 0
    fi

    if ! git -C "$wt_path" diff --quiet 2>/dev/null || ! git -C "$wt_path" diff --cached --quiet 2>/dev/null; then
        echo "ERROR: Worktree '$wt_name' has uncommitted changes:" >&2
        git -C "$wt_path" status --short >&2
        echo "" >&2
        echo "Commit your changes first, or use --force to tear down anyway." >&2
        return 1
    fi
    return 0
}

teardown_worktree() {
    local wt_path="$1"
    local wt_name
    wt_name=$(basename "$wt_path")
    local slug_file="$wt_path/.wt-slug"

    if [ ! -f "$slug_file" ]; then
        return
    fi

    local slug
    slug=$(cat "$slug_file")

    if [ -z "$slug" ]; then
        echo "Warning: Could not determine slug for $wt_name, skipping"
        return
    fi

    # Detect the actual project name from the running container (may differ from convention)
    local project
    project=$(docker inspect "ibl5-php-$slug" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || echo "ibl5-$slug")
    [ -z "$project" ] && project="ibl5-$slug"

    # --env-file ensures ${DB_USER}/${DB_PASS} resolve (same fix as wt-up)
    local env_flag=""
    if [ -f "$REPO_ROOT/.env" ]; then
        env_flag="--env-file $REPO_ROOT/.env"
    fi

    # Stop CSS watcher if running
    local css_pid_file="$wt_path/.css-watch.pid"
    if [ -f "$css_pid_file" ]; then
        local css_pid
        css_pid=$(cat "$css_pid_file")
        kill -9 "$css_pid" 2>/dev/null || true
        rm -f "$css_pid_file" "$wt_path/.css-watch.log"
        echo "  Stopped CSS watcher (PID $css_pid)"
    fi

    # Stop browser-sync if running
    local bs_pid_file="$wt_path/.bs-sync.pid"
    if [ -f "$bs_pid_file" ]; then
        local bs_pid
        bs_pid=$(cat "$bs_pid_file")
        kill -9 "$bs_pid" 2>/dev/null || true
        rm -f "$bs_pid_file" "$wt_path/.bs-sync.log"
        echo "  Stopped browser-sync (PID $bs_pid)"
    fi

    # Export vars so Docker Compose can interpolate the static compose file
    local static_compose="$REPO_ROOT/docker/worktree-compose.yml"
    export SLUG="$slug" WORKTREE_PATH="$wt_path" REPO_ROOT

    echo "Stopping environment: $slug (worktree: $wt_name, project: $project)..."
    # --rmi local removes images built by compose (php, browsersync) while
    # preserving pinned images like mariadb:10.11 shared across worktrees.
    docker compose -f "$static_compose" $env_flag -p "$project" down -v --rmi local

    rm -f "$slug_file"

    echo "  Done."
}

if [ "$ALL" = true ]; then
    WORKTREES_DIR="$REPO_ROOT/worktrees"
    if [ ! -d "$WORKTREES_DIR" ]; then
        echo "No worktrees directory found."
        exit 0
    fi

    found=false
    for wt in "$WORKTREES_DIR"/*/; do
        [ -d "$wt" ] || continue
        if [ -f "$wt/.wt-slug" ]; then
            found=true
            if ! check_uncommitted "$wt"; then
                continue
            fi
            teardown_worktree "$wt"
        fi
    done

    if [ "$found" = false ]; then
        echo "No running worktree environments found."
    fi
    exit 0
fi

if [ -z "$WORKTREE_NAME" ]; then
    echo "Usage: bin/wt-down <worktree-name> [--force]" >&2
    echo "       bin/wt-down --all [--force]" >&2
    echo "" >&2
    echo "Options:" >&2
    echo "  --all      Tear down all worktree environments" >&2
    echo "  --force    Tear down even if worktree has uncommitted changes" >&2
    echo "" >&2
    echo "The DB volume is always removed." >&2
    exit 1
fi

# Resolve the actual worktree path from git (handles worktrees created from
# subdirectories, e.g., ibl5/worktrees/ instead of worktrees/).
WORKTREE_PATH=$(git worktree list --porcelain | awk -v branch="refs/heads/$WORKTREE_NAME" '
    /^worktree / { path = substr($0, 10) }
    $0 == "branch " branch { print path; exit }
')

# Fall back to the conventional location if git doesn't know the branch.
if [ -z "$WORKTREE_PATH" ]; then
    WORKTREE_PATH="$REPO_ROOT/worktrees/$WORKTREE_NAME"
fi

# If the worktree directory is gone (already removed), try to find and stop
# orphaned containers by name pattern (slug = worktree name or pr-NNN).
if [ ! -d "$WORKTREE_PATH" ]; then
    echo "Worktree directory not found at $WORKTREE_PATH"
    echo "Searching for orphaned Docker containers..."

    # Build list of slugs to check: the worktree name itself, plus its
    # PR-based slug (pr-NNN) if the branch has an open PR.
    slugs=("$WORKTREE_NAME")
    pr_slug=$(gh pr view "$WORKTREE_NAME" --json number --jq '.number' 2>/dev/null || true)
    if [ -n "$pr_slug" ]; then
        slugs+=("pr-$pr_slug")
    fi

    found_orphan=false
    for slug in "${slugs[@]}"; do
        php_container="ibl5-php-$slug"
        db_container="ibl5-db-$slug"
        if docker inspect "$php_container" &>/dev/null || docker inspect "$db_container" &>/dev/null; then
            found_orphan=true
            echo "Found orphaned containers for slug: $slug"
            # Get project name from container label
            project=$(docker inspect "$php_container" --format '{{index .Config.Labels "com.docker.compose.project"}}' 2>/dev/null || echo "ibl5-$slug")
            [ -z "$project" ] && project="ibl5-$slug"
            # Stop containers (no compose file, so use docker rm directly)
            for c in "$php_container" "$db_container"; do
                if docker inspect "$c" &>/dev/null; then
                    echo "  Stopping $c..."
                    docker stop "$c" 2>/dev/null || true
                    docker rm "$c" 2>/dev/null || true
                fi
            done
            # Remove volumes
            for vol in $(docker volume ls --format '{{.Name}}' | grep "$slug" || true); do
                echo "  Removing volume: $vol"
                docker volume rm "$vol" 2>/dev/null || true
            done
            # Remove network
            for net in $(docker network ls --format '{{.Name}}' | grep "$project" || true); do
                docker network rm "$net" 2>/dev/null || true
            done
            # Remove built images (php, browsersync) — mariadb is a pinned
            # shared image and won't match these tags.
            for img in "$project-php" "$project-browsersync"; do
                if docker image inspect "$img" &>/dev/null; then
                    echo "  Removing image: $img"
                    docker rmi "$img" 2>/dev/null || true
                fi
            done
            echo "  Done."
        fi
    done

    if [ "$found_orphan" = false ]; then
        echo "No orphaned containers found for '$WORKTREE_NAME'."
    fi
    exit 0
fi

if [ ! -f "$WORKTREE_PATH/.wt-slug" ]; then
    echo "No Docker environment found for worktree '$WORKTREE_NAME'."
    echo "(No .wt-slug in $WORKTREE_PATH)"
    exit 0
fi

if ! check_uncommitted "$WORKTREE_PATH"; then
    exit 1
fi

teardown_worktree "$WORKTREE_PATH"
