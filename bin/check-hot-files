#!/bin/bash
# Lists files in classes/ over THRESHOLD lines; with --pr, flags files that
# are currently over THRESHOLD and received > 100 new lines in the current PR.
set -euo pipefail

THRESHOLD=${HOT_FILE_THRESHOLD:-500}
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT/ibl5"

echo "=== Hot files (> $THRESHOLD LOC) ==="
find classes -name '*.php' -exec wc -l {} \; | \
  awk -v t="$THRESHOLD" '$1 > t { printf "%6d %s\n", $1, $2 }' | sort -rn

if [ "${1:-}" = "--pr" ]; then
    echo
    echo "=== Files in current PR that grew > 100 LOC ==="
    flagged=0
    while read -r added removed file; do
        if [ "$added" = "-" ]; then
            continue
        fi
        if [ "$added" -gt 100 ]; then
            current=$(wc -l < "$ROOT/$file" 2>/dev/null || echo 0)
            current=$(echo "$current" | tr -d ' ')
            if [ "$current" -gt "$THRESHOLD" ]; then
                echo "FLAG: $file (now $current LOC, +$added in this PR)"
                flagged=1
            fi
        fi
    done < <(git diff origin/master --numstat -- 'classes/**/*.php')
    if [ "$flagged" = "0" ]; then
        echo "No hot-file growth detected in this PR."
    fi
fi
