{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["classes"],
        "excludes": [
            "*/Contracts/*",
            "Bootstrap", "Database",
            "OneOnOneGame",
            // Repositories without direct test coverage (Pass 2 — deferred)
            "ApiKeys/ApiKeysRepository.php",
            "BaseMysqliRepository.php",
            "PlrParser/PlrBoxScoreRepository.php",
            "Voting/VotingRepository.php",
            // Views without companion tests (Pass 2 — deferred)
            "Boxscore/BoxscoreView.php",
            "FreeAgency/FreeAgencyOfferView.php",
            "FreeAgency/FreeAgencyView.php",
            "FreeAgency/FreeAgencyFormComponents.php",
            "LeagueConfig/LeagueConfigView.php",
            "LeagueStarters/LeagueStartersView.php",
            "Negotiation/NegotiationDemandsBreakdownView.php",
            "Player/Views/PlayerAwardsAndNewsView.php",
            "Player/Views/PlayerAwardsView.php",
            "Player/Views/PlayerButtonsView.php",
            "Player/Stats/Views/PlayerHeatAveragesView.php",
            "Player/Stats/Views/PlayerHeatStatsView.php",
            "Player/Stats/Views/PlayerHeatTotalsView.php",
            "Player/Views/PlayerMenuView.php",
            "Player/Stats/Views/PlayerOlympicAveragesView.php",
            "Player/Stats/Views/PlayerOlympicTotalsView.php",
            "Player/Stats/Views/PlayerOlympicsStatsView.php",
            "Player/Views/PlayerOneOnOneView.php",
            "Player/Views/PlayerOverviewView.php",
            "Player/Stats/Views/PlayerPlayoffAveragesView.php",
            "Player/Stats/Views/PlayerPlayoffStatsView.php",
            "Player/Stats/Views/PlayerPlayoffTotalsView.php",
            "Player/Stats/Views/PlayerRatingsAndSalaryView.php",
            "Player/Stats/Views/PlayerRegularSeasonAveragesView.php",
            "Player/Stats/Views/PlayerRegularSeasonTotalsView.php",
            "Player/Stats/Views/PlayerSeasonStatsView.php",
            "Player/Stats/Views/PlayerSimStatsView.php",
            "Player/Views/PlayerTradingCardBackView.php",
            "Player/Views/PlayerTradingCardFlipView.php",
            "Player/Views/PlayerTradingCardFrontView.php",
            // Controllers without direct test coverage (Pass 2 — deferred)
            "Player/PlayerPageController.php",
            "Updater/UpdaterController.php",
            "Api/Controller/PlayerExportController.php",
            "Api/Controller/TeamDetailController.php",
            "Api/Controller/GameDetailController.php",
            "Api/Controller/PlayerDetailController.php",
            "Api/Controller/TeamListController.php",
            "Api/Controller/PlayerHistoryController.php",
            "Api/Controller/SeasonController.php",
            "Api/Controller/TeamRosterController.php",
            "Api/Controller/PlayerListController.php",
            "Api/Controller/GameBoxscoreController.php",
            // Handlers without direct test coverage (Pass 2 — deferred)
            "NextSim/NextSimTabApiHandler.php",
            "Team/TeamApiHandler.php"
        ]
    },
    "phpUnit": {
        "configDir": ".",
        "customPath": "vendor/bin/phpunit"
    },
    "mutators": {
        "@default": true,
        "CastFloat": false,
        "CastInt": false,
        "CastString": false
    },
    "testFramework": "phpunit",
    "testFrameworkOptions": "--configuration=phpunit-mutation.xml",
    "minMsi": 100,
    "minCoveredMsi": 100,
    "threads": 4,
    "logs": {
        "text": "infection.log",
        "html": "infection-report.html",
        "summary": "infection-summary.log"
    },
    "tmpDir": "/tmp"
}
