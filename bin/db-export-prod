#!/bin/bash
# Export production database for use in worktree Docker environments.
# Tables with STORED GENERATED columns are automatically detected and excluded
# from the data dump (their schema is still included). Import box scores
# separately via bin/db-import-boxscores.
#
# Usage: bin/db-export-prod
#
# Connection: reads REMOTE_* from .env for production, falls back to local Docker.
# Output: ibl5/fixtures/prod-seed.sql (gitignored)

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
OUTPUT="$REPO_ROOT/ibl5/fixtures/prod-seed.sql"

# Source .env for database credentials
ENV_FILE="$REPO_ROOT/.env"
if [ -f "$ENV_FILE" ]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
fi

# Determine connection mode: remote production or local Docker
if [ -n "${REMOTE_HOST:-}" ] && [ "$REMOTE_HOST" != "localhost" ] && [ "$REMOTE_HOST" != "127.0.0.1" ]; then
    DB_HOST="$REMOTE_HOST"
    DB_PORT="${REMOTE_PORT:-3306}"
    DB_USER_VAL="$REMOTE_USER"
    DB_PASS_VAL="$REMOTE_PASSWORD"
    DB_NAME="${REMOTE_DATABASE:-iblhoops_ibl5}"
    EXTRA_OPTS="--compress"
    echo "Mode: remote production ($DB_HOST:$DB_PORT)"
else
    # REMOTE_HOST unset — exit silently (safe for background hook use)
    if [ -z "${REMOTE_HOST:-}" ]; then
        exit 0
    fi
    # REMOTE_HOST is localhost/127.0.0.1 — use local Docker
    DB_HOST="127.0.0.1"
    DB_PORT="3306"
    DB_USER_VAL="root"
    DB_PASS_VAL="root"
    DB_NAME="iblhoops_ibl5"
    EXTRA_OPTS=""
    echo "Mode: local Docker ($DB_HOST)"
fi

DUMP_OPTS="--skip-ssl --single-transaction --skip-lock-tables $EXTRA_OPTS"

echo "Exporting production DB..."

# Helper: run a mariadb query
db_query() {
    MYSQL_PWD="$DB_PASS_VAL" mariadb -h "$DB_HOST" -P "$DB_PORT" --skip-ssl \
        -u "$DB_USER_VAL" "$DB_NAME" -N -e "$1"
}

# Dynamically detect tables with STORED GENERATED columns.
# mariadb-dump includes values for generated columns in INSERT statements, but
# Docker MariaDB 10.6 rejects them with ERROR 1906. Skip data export for these
# tables entirely. (ibl_box_scores/ibl_box_scores_teams are imported separately
# via bin/db-import-boxscores; other tables with generated columns get their data
# from the CREATE TABLE + migrations, or need a similar dedicated import script.)
GENERATED_TABLES=$(db_query "
    SELECT DISTINCT table_name
    FROM information_schema.columns
    WHERE table_schema='$DB_NAME'
      AND extra LIKE '%GENERATED%'
    ORDER BY table_name;
")

# Build a regex from the dynamically-detected list
SKIP_REGEX=""
for tbl in $GENERATED_TABLES; do
    if [ -z "$SKIP_REGEX" ]; then
        SKIP_REGEX="^($tbl"
    else
        SKIP_REGEX="$SKIP_REGEX|$tbl"
    fi
done
if [ -n "$SKIP_REGEX" ]; then
    SKIP_REGEX="$SKIP_REGEX)$"
    echo "Skipping data for tables with generated columns: $GENERATED_TABLES"
else
    SKIP_REGEX="^$"  # match nothing
fi

# Helper: run mariadb-dump with given args
db_dump() {
    # shellcheck disable=SC2086
    MYSQL_PWD="$DB_PASS_VAL" mariadb-dump -h "$DB_HOST" -P "$DB_PORT" \
        -u "$DB_USER_VAL" $DUMP_OPTS "$@"
}

# 1. Fetch table and view lists in a single query (one round trip)
TABLE_META=$(db_query "
    SELECT CONCAT(IF(engine IS NOT NULL, 'T', 'V'), '|', table_name)
    FROM information_schema.tables
    WHERE table_schema='$DB_NAME'
    ORDER BY table_name;
")

ALL_TABLES=""
REGULAR_TABLES=""
VIEWS=""
for row in $TABLE_META; do
    kind="${row%%|*}"
    name="${row#*|}"
    if [ "$kind" = "T" ]; then
        ALL_TABLES="$ALL_TABLES $name"
        if ! echo "$name" | grep -qE "$SKIP_REGEX"; then
            REGULAR_TABLES="$REGULAR_TABLES $name"
        fi
    else
        VIEWS="$VIEWS $name"
    fi
done

mkdir -p "$(dirname "$OUTPUT")"
TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

# 2. Dump structure for ALL tables (including box scores) — no data
#    Include --routines and --triggers here (only in this step)
#    stderr is NOT suppressed — surface mariadb-dump errors instead of silently
#    producing a header-only file (which was the root cause of missing CREATE TABLEs).
echo "-- Dumping table structure..."
db_dump --routines --triggers --no-data "$DB_NAME" > "$OUTPUT"

# Validate that the structure dump actually produced CREATE TABLE statements.
# mariadb-dump writes a valid header even on connection/auth errors, so the file
# can appear non-empty while containing zero DDL.
if ! grep -q 'CREATE TABLE' "$OUTPUT"; then
    echo "Error: Structure dump contains no CREATE TABLE statements." >&2
    echo "Check database credentials and mariadb-dump connectivity." >&2
    rm -f "$OUTPUT"
    exit 1
fi
# Check that the dump completed — mariadb-dump writes a trailer comment.
# A missing trailer means the connection was interrupted mid-output.
if ! grep -q '^-- Dump completed' "$OUTPUT"; then
    echo "Error: Structure dump appears truncated (no 'Dump completed' marker)." >&2
    echo "The remote connection may have been interrupted. Re-run the export." >&2
    rm -f "$OUTPUT"
    exit 1
fi

# 3. Dump data and views in parallel
#    Each mariadb-dump opens a new connection, so parallelising saves round trips.
PIDS=""

echo "-- Dumping data for regular tables..."
# shellcheck disable=SC2086
db_dump --no-create-info --skip-triggers "$DB_NAME" $REGULAR_TABLES \
    > "$TMPDIR/regular.sql" &
PIDS="$PIDS $!"

if [ -n "$VIEWS" ]; then
    echo "-- Dumping views..."
    # shellcheck disable=SC2086
    db_dump "$DB_NAME" $VIEWS > "$TMPDIR/views.sql" &
    PIDS="$PIDS $!"
fi

# Wait for all background dumps; fail if any errored
for pid in $PIDS; do
    if ! wait "$pid"; then
        echo "Error: a parallel dump job (PID $pid) failed." >&2
        rm -f "$OUTPUT"
        exit 1
    fi
done

# 4. Concatenate in deterministic order: regular data → views
#    Each mariadb-dump invocation writes its own preamble (sandbox comment, SET
#    @OLD_* statements) and postamble (Dump completed trailer). Strip them from
#    appended files to prevent duplicate session-variable resets and, critically,
#    a corrupted line if the structure dump lacks a trailing newline.
strip_dump_wrapper() {
    sed -E \
        -e '/^\/\*M!999999/d' \
        -e '/^-- MariaDB dump/d' \
        -e '/^-- Host:/d' \
        -e '/^-- -+$/d' \
        -e '/^-- Server version/d' \
        -e '/^-- Dump completed/d' \
        -e '/^\/\*![0-9]+ SET @OLD_/d' \
        -e '/^\/\*![0-9]+ SET TIME_ZONE=@OLD/d' \
        -e '/^\/\*![0-9]+ SET SQL_MODE=@OLD/d' \
        -e '/^\/\*![0-9]+ SET CHARACTER_SET/d' \
        -e '/^\/\*![0-9]+ SET character_set_client/d' \
        -e '/^\/\*![0-9]+ SET UNIQUE_CHECKS=@OLD/d' \
        -e '/^\/\*![0-9]+ SET FOREIGN_KEY_CHECKS=@OLD/d' \
        -e '/^\/\*M!100616 SET NOTE_VERBOSITY=@OLD/d' \
        "$1"
}

# Ensure the structure dump ends with a newline — guards against truncated
# output from a flaky remote connection splicing the next file mid-line.
[ -s "$OUTPUT" ] && [ "$(tail -c 1 "$OUTPUT" | wc -l)" -eq 0 ] && echo >> "$OUTPUT"

# The structure dump's postamble restores FOREIGN_KEY_CHECKS=@OLD (=1).
# Data inserts follow in alphabetical table order, so tables with FK references
# (e.g. ibl_cash_considerations → ibl_team_info) may be inserted before their
# referenced tables. Re-disable FK checks for the data section.
echo '/*!40014 SET FOREIGN_KEY_CHECKS=0 */;' >> "$OUTPUT"

strip_dump_wrapper "$TMPDIR/regular.sql" >> "$OUTPUT"
[ -f "$TMPDIR/views.sql" ] && strip_dump_wrapper "$TMPDIR/views.sql" >> "$OUTPUT"

# Re-enable FK checks at the end so the imported DB is in a normal state
echo '/*!40014 SET FOREIGN_KEY_CHECKS=1 */;' >> "$OUTPUT"

# 5. Strip DEFINER clauses — prod exports contain DEFINER=user@host that may
#    not match the Docker MariaDB user, causing ERROR 1449 on import.
perl -pi -e 's/ DEFINER=[^ ]* / /g' "$OUTPUT"

SIZE=$(du -h "$OUTPUT" | cut -f1)
echo ""
echo "Done: $OUTPUT ($SIZE)"
echo ""
if [ -n "$GENERATED_TABLES" ]; then
    echo "Tables with generated columns were excluded (data only — schema is included):"
    for tbl in $GENERATED_TABLES; do
        echo "  - $tbl"
    done
    echo ""
    echo "For box scores, import separately: bin/db-import-boxscores --remote"
fi
