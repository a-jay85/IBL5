#!/bin/bash
# Start browser-sync with live reload for a Docker PHP container.
# Usage: bin/bs-start [slug] [port]
#   slug defaults to "main", port defaults to 3000
#   Browse at http://localhost:PORT/ibl5/

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SLUG="${1:-main}"
BS_PORT="${2:-3000}"
IBL5="$REPO_ROOT/ibl5"

echo "Browser-sync: http://localhost:$BS_PORT/ibl5/"
echo "Proxying:     http://$SLUG.localhost"

cd "$IBL5"
exec bunx browser-sync start \
    --proxy "$SLUG.localhost" \
    --port "$BS_PORT" \
    --files "$IBL5/themes/IBL/style/style.css,$IBL5/classes/**/*.php,$IBL5/modules/**/*.php" \
    --no-open --no-ui --no-ghost-mode
