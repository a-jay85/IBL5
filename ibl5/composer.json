{
    "require": {
        "php": ">=8.5",
        "phpmailer/phpmailer": "^7.0",
        "delight-im/auth": "^9.0",
        "monolog/monolog": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-phpunit": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "infection/infection": "^0.33.2"
    },
    "scripts": {
        "pre-autoload-dump": "if [ -L vendor ]; then echo 'ERROR: vendor/ is a symlink (worktree). Do not run composer install/dump-autoload here — it corrupts shared autoload paths. Run from the main repo instead.' && exit 1; fi",
        "test": "vendor/bin/phpunit",
        "test:db": "vendor/bin/phpunit --group database",
        "test:all": "vendor/bin/phpunit --group default --group database",
        "lint:php": "vendor/bin/phpcs --standard=PSR12 src",
        "lint:php:fix": "vendor/bin/phpcbf --standard=PSR12 src",
        "analyse": "vendor/bin/phpstan analyse --configuration=phpstan.neon --autoload-file=phpstan-stubs/phpstan-rules-bootstrap.php --memory-limit=1G",
        "analyse:tests": "vendor/bin/phpstan analyse --configuration=phpstan-tests.neon --autoload-file=phpstan-stubs/phpstan-rules-bootstrap.php --memory-limit=1G",
        "analyse:tests:baseline": "vendor/bin/phpstan clear-result-cache --configuration=phpstan-tests.neon && vendor/bin/phpstan analyse --configuration=phpstan-tests.neon --autoload-file=phpstan-stubs/phpstan-rules-bootstrap.php --generate-baseline=phpstan-tests-baseline.neon --memory-limit=1G",
        "analyse:baseline": "vendor/bin/phpstan clear-result-cache --configuration=phpstan.neon && vendor/bin/phpstan analyse --configuration=phpstan.neon --autoload-file=phpstan-stubs/phpstan-rules-bootstrap.php --generate-baseline --memory-limit=1G",
        "mutation": "vendor/bin/infection --configuration=infection.json5 --coverage=coverage",
        "mutation:controllers-handlers": "vendor/bin/infection --configuration=infection.json5 --coverage=coverage --filter=\"$(cat tests/Mutation/controllers-handlers-pass1-paths.txt | tr '\\n' ',' | sed 's|,$||')\"",
        "mutation:small-modules": "vendor/bin/infection --configuration=infection.json5 --coverage=coverage --filter=\"$(cat tests/Mutation/small-modules-pass1-paths.txt | tr '\\n' ',' | sed 's|,$||')\"",
        "mutation:views": "vendor/bin/infection --configuration=infection.json5 --coverage=coverage --filter=\"$(cat tests/Mutation/views-pass-paths.txt | tr '\\n' ',' | sed 's|,$||')\""
    },
    "autoload": {
        "psr-4": {
            "": "classes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "PHPStanRules\\": "phpstan-rules/"
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true,
            "infection/extension-installer": true
        }
    }
}
