# Database Configuration
# Copy this file to .env and fill in your MySQL credentials

# Database Host
DB_HOST=localhost

# Database User (read-only recommended for security)
DB_USER=your_database_user

# Database Password
DB_PASSWORD=your_database_password

# Database Name
DB_NAME=ibl5

# Optional: Unix socket path (useful for MAMP on macOS)
# Comment out if using TCP connection
# DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# Node Environment
NODE_ENV=development

# Optional: Connection Pool Settings
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0

# Optional: Query Timeout (milliseconds)
# DB_TIMEOUT=30000
