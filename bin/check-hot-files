#!/bin/bash
# Lists files in classes/ over THRESHOLD lines; with --pr, flags files in the
# current PR that grew > 100 LOC past the threshold.
set -euo pipefail

THRESHOLD=${HOT_FILE_THRESHOLD:-500}
ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT/ibl5"

echo "=== Hot files (> $THRESHOLD LOC) ==="
find classes -name '*.php' -exec wc -l {} \; | \
  awk -v t="$THRESHOLD" '$1 > t { printf "%6d %s\n", $1, $2 }' | sort -rn

if [ "${1:-}" = "--pr" ]; then
    echo
    echo "=== Files in current PR that grew > 100 LOC ==="
    flagged=0
    git diff origin/master --numstat -- 'classes/**/*.php' | while read -r added removed file; do
        if [ "$added" = "-" ]; then
            continue
        fi
        if [ "$added" -gt 100 ]; then
            current=$(wc -l < "$file" 2>/dev/null || echo 0)
            current=$(echo "$current" | tr -d ' ')
            if [ "$current" -gt "$THRESHOLD" ]; then
                echo "FLAG: $file (now $current LOC, +$added in this PR)"
                flagged=1
            fi
        fi
    done
    if [ "$flagged" = "0" ]; then
        echo "No hot-file growth detected in this PR."
    fi
fi
