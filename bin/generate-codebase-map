#!/bin/bash
# Generate .claude/rules/codebase-map.md from ibl5/classes/ structure.
# Run: bin/generate-codebase-map
# Auto-run: SessionStart hook + git pre-commit hook

set -euo pipefail

# Deterministic output: force byte-order sort regardless of user locale
export LC_ALL=C

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CLASSES_DIR="$REPO_ROOT/ibl5/classes"
OUTPUT="$REPO_ROOT/.claude/rules/codebase-map.md"

# Third-party / built-in namespaces to exclude from dependency graph
EXCLUDE_NS="Delight|Monolog|PHPMailer|Psr|ZipArchive|SplFileObject|DateTimeImmutable|DateTime|RuntimeException|InvalidArgumentException|LogicException|Override|JsonSerializable|Stringable|BackedEnum|UnitEnum|ValueError|Fiber|WeakMap"

# Temp file for dependency lines (collected during first pass)
DEP_LINES=$(mktemp)
trap 'rm -f "$DEP_LINES"' EXIT

TODAY=$(date +%Y-%m-%d)

{
cat <<HEADER
---
description: Auto-generated module map of ibl5/classes/ with file counts, roles, and cross-module dependencies.
paths: ibl5/classes/**/*.php
last_verified: ${TODAY}
---

# Codebase Module Map

Auto-generated by \`bin/generate-codebase-map\`. Do not edit manually.

**Legend:** R=Repository S=Service V=View Ct=Controller P=Processor Vl=Validator | C=has Contracts/ dir

## Module Index

| Module | Files | C | Roles | Subdirs |
|--------|------:|:-:|-------|---------|
HEADER

# Single pass: module index + collect dependencies
for dir in "$CLASSES_DIR"/*/; do
    module=$(basename "$dir")

    # Count PHP files at module root (not in Contracts/)
    files=0 R=0 S=0 V=0 Ct=0 P=0 Vl=0
    while IFS= read -r f; do
        [ -z "$f" ] && continue
        fname=$(basename "$f")
        files=$((files + 1))
        case "$fname" in
            *Repository.php)  R=$((R + 1)) ;;
            *Service.php)     S=$((S + 1)) ;;
            *View.php)        V=$((V + 1)) ;;
            *Controller.php)  Ct=$((Ct + 1)) ;;
            *Processor.php)   P=$((P + 1)) ;;
            *Validator.php)   Vl=$((Vl + 1)) ;;
        esac
    done < <(find "$dir" -maxdepth 1 -name '*.php' -type f 2>/dev/null)

    # Contracts/
    contracts="-"
    [ -d "$dir/Contracts" ] && contracts="Y"

    # Roles string (only non-zero)
    roles=""
    [ $R -gt 0 ]  && roles="${roles}R${R} "
    [ $S -gt 0 ]  && roles="${roles}S${S} "
    [ $V -gt 0 ]  && roles="${roles}V${V} "
    [ $Ct -gt 0 ] && roles="${roles}Ct${Ct} "
    [ $P -gt 0 ]  && roles="${roles}P${P} "
    [ $Vl -gt 0 ] && roles="${roles}Vl${Vl} "
    roles="${roles% }"

    # Non-Contracts subdirectories
    subdirs=""
    for sub in "$dir"*/; do
        [ -d "$sub" ] || continue
        subname=$(basename "$sub")
        [ "$subname" = "Contracts" ] && continue
        subdirs="${subdirs}${subname} "
    done
    subdirs="${subdirs% }"

    printf "| %s | %d | %s | %s | %s |\n" "$module" "$files" "$contracts" "$roles" "$subdirs"

    # Collect dependencies (same pass)
    deps=$(grep -rh '^use ' "$dir" --include='*.php' 2>/dev/null \
        | sed 's/^use //;s/;.*//' \
        | awk -F'\\\\' '{print $1}' \
        | grep -vE "^($module|$EXCLUDE_NS)$" \
        | sort -u \
        | tr '\n' ' ' || true)
    deps="${deps% }"
    [ -n "$deps" ] && echo "$module -> $deps" >> "$DEP_LINES"
done

# Root-level loose files
echo ""
echo "**Root files:** $(find "$CLASSES_DIR" -maxdepth 1 -name '*.php' -print0 2>/dev/null | xargs -0 -I{} basename {} .php | sort | tr '\n' ' ' | sed 's/ $//')"

# Section B: Dependencies (from collected data)
echo ""
echo "## Cross-Module Dependencies"
echo ""
cat "$DEP_LINES"

# Usage guidance
cat <<'FOOTER'

## Usage

When working in a module, use targeted paths instead of broad searches:
- `Glob("ibl5/classes/ModuleName/**/*.php")` for all module files
- `Glob("ibl5/classes/ModuleName/Contracts/*.php")` for interfaces
- Check the dependency list above to identify related modules
FOOTER

} > "$OUTPUT"
