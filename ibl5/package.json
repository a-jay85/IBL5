{
  "name": "ibl5-design",
  "version": "1.0.0",
  "description": "IBL5 Design System with Tailwind CSS 4",
  "type": "module",
  "scripts": {
    "css:watch": "bunx @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css --watch",
    "css:build": "bunx @tailwindcss/cli -i design/input.css -o themes/IBL/style/style.css --minify",
    "sync": "bunx browser-sync start --proxy main.localhost --files 'themes/IBL/style/style.css' 'classes/**/*.php' 'modules/**/*.php' --no-open --no-ui --no-ghost-mode",
    "test:api": "bunx vitest run --config vitest.api.config.ts",
    "test:e2e": "bunx playwright test",
    "test:e2e:serial": "bunx playwright test --workers=1 --retries=2",
    "test:e2e:headed": "bunx playwright test --headed",
    "test:e2e:ui": "bunx playwright test --ui",
    "test:e2e:a11y": "bunx playwright test tests/e2e/smoke/accessibility.spec.ts",
    "test:e2e:isolated": "./bin/e2e-local.sh",
    "test:e2e:visual": "./bin/visual-regression.sh",
    "test:e2e:visual:update": "./bin/visual-regression.sh --update-snapshots",
    "docker:up": "cd .. && docker compose up -d",
    "docker:down": "cd .. && docker compose down",
    "docker:logs": "cd .. && docker compose logs -f php",
    "wt:up": "cd .. && bin/wt-up",
    "wt:down": "cd .. && bin/wt-down",
    "wt:list": "cd .. && bin/wt-list",
    "lighthouse": "bunx @lhci/cli autorun",
    "smoke:prod": "cd .. && bin/smoke-prod"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/cli": "^4.0.0",
    "browser-sync": "^3.0.4",
    "tailwindcss": "^4.0.0",
    "vitest": "^4.1.0"
  }
}
