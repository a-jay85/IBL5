#!/bin/bash
# Remove a git worktree and its Docker environment.
# Tears down Docker containers first (if running), then removes the worktree.
# Uses --force for git because symlinked files (vendor, config.php, .env.test,
# node_modules) appear as untracked changes and block normal removal.
#
# Usage: bin/wt-remove <worktree-name> [--force] [--volumes]

set -euo pipefail

source "$(dirname "$0")/lib/wt-guards.sh"

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

NAME=""
FORCE=false
VOLUMES=false
for arg in "$@"; do
    case "$arg" in
        --force) FORCE=true ;;
        --volumes) VOLUMES=true ;;
        -*) echo "Unknown option: $arg" >&2; exit 1 ;;
        *) NAME="$arg" ;;
    esac
done

if [ -z "$NAME" ]; then
    echo "Usage: bin/wt-remove <worktree-name> [--force] [--volumes]" >&2
    exit 1
fi

# Resolve the actual worktree path from git (handles worktrees created from
# subdirectories, e.g., ibl5/worktrees/ instead of worktrees/).
WT_PATH=$(git worktree list --porcelain | awk -v branch="refs/heads/$NAME" '
    /^worktree / { path = substr($0, 10) }
    $0 == "branch " branch { print path; exit }
')

# Fall back to the conventional location if git doesn't know the branch
# (e.g., branch already deleted but directory remains).
if [ -z "$WT_PATH" ]; then
    WT_PATH="$REPO_ROOT/worktrees/$NAME"
fi

if [ ! -d "$WT_PATH" ]; then
    echo "Error: worktree '$NAME' not found at $WT_PATH" >&2
    exit 1
fi

# Safety: refuse to remove a worktree that is actively in use
if [ "$FORCE" != true ] && is_worktree_in_use "$WT_PATH"; then
    echo "Error: worktree '$NAME' is in active use (processes detected in directory)" >&2
    echo "Use --force to remove anyway." >&2
    exit 1
fi

# Tear down Docker environment if one exists (prevents orphaned containers)
if [ -f "$WT_PATH/.wt-slug" ]; then
    echo "Tearing down Docker environment..."
    DOWN_FLAGS=""
    [ "$VOLUMES" = true ] && DOWN_FLAGS="$DOWN_FLAGS --volumes"
    [ "$FORCE" = true ] && DOWN_FLAGS="$DOWN_FLAGS --force"
    # shellcheck disable=SC2086
    "$REPO_ROOT/bin/wt-down" "$NAME" $DOWN_FLAGS || true
fi

echo "Removing worktree '$NAME'..."
git worktree remove --force "$WT_PATH"
echo "Done. Worktree '$NAME' removed."
